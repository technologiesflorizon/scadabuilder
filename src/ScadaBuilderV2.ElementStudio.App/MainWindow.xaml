<Window x:Class="ScadaBuilderV2.ElementStudio.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Studio Element+"
        Height="920"
        Width="1480"
        MinHeight="720"
        MinWidth="1120"
        Background="#F7FBF5">
    <Window.Resources>
        <SolidColorBrush x:Key="InkBrush" Color="#0F2A30"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#4E6A71"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#FFFFFF"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#260F2A30"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#90C030"/>
        <SolidColorBrush x:Key="AccentBlueBrush" Color="#2090A0"/>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
        </Style>

        <Style x:Key="MenuButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="RibbonCommandButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="104"/>
            <Setter Property="Height" Value="52"/>
        </Style>

        <Style x:Key="ElementListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#EAF5F7"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#2090A0"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#0F7280"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top"
                Height="118"
                Background="#F2F8EF"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="78"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="14,6,14,0">
                    <TextBlock DockPanel.Dock="Right"
                               Text="{Binding PackageSummary}"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource MutedBrush}"
                               FontWeight="SemiBold"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Fichier" Style="{StaticResource MenuButtonStyle}" Click="OnRibbonTabClick" Tag="File"/>
                        <Button Content="Edition" Style="{StaticResource MenuButtonStyle}" Click="OnRibbonTabClick" Tag="Edit"/>
                        <Button Content="Vue" Style="{StaticResource MenuButtonStyle}" Click="OnRibbonTabClick" Tag="View"/>
                        <Button Content="Element+" Style="{StaticResource MenuButtonStyle}" Click="OnRibbonTabClick" Tag="ElementPlus"/>
                        <Button Content="Exporter" Style="{StaticResource MenuButtonStyle}" Click="OnRibbonTabClick" Tag="Export"/>
                    </StackPanel>
                </DockPanel>

                <Border Grid.Row="1"
                        Margin="14,6,14,8"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <Grid Margin="8">
                        <StackPanel x:Name="FileRibbon" Orientation="Horizontal">
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Ouvrir .ft1" Click="OnUnavailableCommandClick" Tag="Ouvrir .ft1"/>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Enregistrer" Click="OnSaveComponentClick"/>
                            <StackPanel Orientation="Horizontal" Margin="3,3,0,3">
                                <Button x:Name="AddToLibraryButton" Style="{StaticResource RibbonCommandButtonStyle}" Width="84" Margin="0" Content="Ajouter a la librairie" Click="OnSaveComponentAsClick"/>
                                <Button x:Name="AddToLibraryArrowButton" Style="{StaticResource RibbonCommandButtonStyle}" Width="20" Margin="0" Content="&#9662;" Click="OnAddToLibraryArrowClick"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel x:Name="EditRibbon" Orientation="Horizontal" Visibility="Collapsed">
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Annuler" Click="OnUndoClick"/>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Retablir" Click="OnRedoClick"/>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Supprimer" Click="OnDeleteSelectionClick"/>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Copier" Click="OnCopySelectionClick"/>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Coller" Click="OnPasteSelectionClick"/>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Dupliquer" Click="OnDuplicateSelectionClick"/>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Cacher" Click="OnHideSelectionClick"/>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Afficher" Click="OnShowAllClick"/>
                        </StackPanel>
                        <StackPanel x:Name="ViewRibbon" Orientation="Horizontal" Visibility="Collapsed">
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Zoom -" Click="OnZoomOutClick"/>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Zoom +" Click="OnZoomInClick"/>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="100%" Click="OnResetZoomClick"/>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Zone -" Click="OnShrinkWorkzoneClick"/>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Zone +" Click="OnGrowWorkzoneClick"/>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Fit zone" Click="OnFitWorkzoneClick"/>
                            <StackPanel Width="132" Margin="8,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="{Binding WorkzoneZoomText}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding WorkzoneSizeText}" Foreground="{StaticResource MutedBrush}"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel x:Name="ElementPlusRibbon" Orientation="Horizontal" Visibility="Collapsed">
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Grouper" Click="OnGroupSelectionClick"/>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Degrouper" Click="OnUngroupSelectionClick"/>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Lock" Click="OnLockSelectionClick"/>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Unlock" Click="OnUnlockAllClick"/>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Align G" Click="OnAlignLeftClick"/>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Align C" Click="OnAlignCenterClick"/>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Align D" Click="OnAlignRightClick"/>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Align H" Click="OnAlignTopClick"/>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Align M" Click="OnAlignMiddleClick"/>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Align B" Click="OnAlignBottomClick"/>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Dist H" Click="OnDistributeHorizontalClick"/>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Dist V" Click="OnDistributeVerticalClick"/>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Larg =" Click="OnEqualizeWidthClick"/>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Haut =" Click="OnEqualizeHeightClick"/>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Creer SVG" Click="OnCreateSvgComponentClick"/>
                        </StackPanel>
                        <StackPanel x:Name="ExportRibbon" Orientation="Horizontal" Visibility="Collapsed">
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Valider" Click="OnUnavailableCommandClick" Tag="Valider"/>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Publier" Click="OnUnavailableCommandClick" Tag="Publier"/>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Librairie" Click="OnUnavailableCommandClick" Tag="Librairie"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom"
                Height="34"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,1,0,0">
            <DockPanel Margin="12,0">
                <TextBlock DockPanel.Dock="Right"
                           Text="Studio Element+"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource InkBrush}"
                           FontWeight="Bold"/>
                <TextBlock Text="{Binding SelectionSummary}"
                           VerticalAlignment="Center"
                           Foreground="{StaticResource MutedBrush}"/>
            </DockPanel>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280" MinWidth="220"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="520"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="330" MinWidth="260"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="150"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Grid.Column="0"
                    Grid.RowSpan="2"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="0,0,1,0">
                <DockPanel Margin="12">
                    <TextBlock DockPanel.Dock="Top"
                               Text="Outils de dessin"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource InkBrush}"
                               Margin="0,0,0,8"/>
                    <UniformGrid x:Name="ToolButtonPanel"
                                 DockPanel.Dock="Top"
                                 Columns="2"
                                 Margin="0,0,0,12">
                        <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Selection" Click="OnToolClick" Tag="Selection"/>
                        <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Ligne" Click="OnToolClick" Tag="Ligne"/>
                        <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Polyline" Click="OnToolClick" Tag="Polyline"/>
                        <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Polygone" Click="OnToolClick" Tag="Polygone"/>
                        <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Rectangle" Click="OnToolClick" Tag="Rectangle"/>
                        <Button Style="{StaticResource RibbonCommandButtonStyle}" Content="Image" Click="OnToolClick" Tag="Image"/>
                    </UniformGrid>
                    <StackPanel>
                        <TextBlock Text="Creation d'icones"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource InkBrush}"
                                   Margin="0,4,0,6"/>
                        <TextBlock Text="{Binding ActiveToolSummary}"
                                   FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBlueBrush}"
                                   Margin="0,0,0,6"/>
                        <TextBlock Text="Les outils actifs pour dessiner, nettoyer et composer les Element+ seront centralises ici."
                                   TextWrapping="Wrap"
                                   Foreground="{StaticResource MutedBrush}"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <GridSplitter Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" Width="5" HorizontalAlignment="Stretch"/>

            <Border Grid.Row="0"
                    Grid.Column="2"
                    Margin="14"
                    Background="#E7EEF0"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="6">
                <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                    <Grid x:Name="WorkzoneSurface"
                          Width="{Binding WorkzoneScaledWidth}"
                          Height="{Binding WorkzoneScaledHeight}"
                          Margin="24"
                          Background="#FDFEFE">
                        <Grid.Effect>
                            <DropShadowEffect BlurRadius="14" ShadowDepth="2" Opacity="0.16"/>
                        </Grid.Effect>
                        <Grid ClipToBounds="True">
                            <wv2:WebView2 x:Name="LegacySourceWebView"/>
                        </Grid>
                    </Grid>
                </ScrollViewer>
            </Border>

            <GridSplitter Grid.Row="0" Grid.Column="3" Grid.RowSpan="2" Width="5" HorizontalAlignment="Stretch"/>

            <Border Grid.Row="0"
                    Grid.Column="4"
                    Grid.RowSpan="2"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1,0,0,0">
                <TabControl>
                    <TabItem Header="Element">
                        <DockPanel Margin="12">
                            <TextBlock DockPanel.Dock="Top"
                                       Text="Elements importes"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource InkBrush}"
                                       Margin="0,0,0,8"/>
                            <ListBox x:Name="ElementListBox"
                                     ItemsSource="{Binding ImportedItems}"
                                     SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                                     DisplayMemberPath="DisplayName"
                                     SelectionMode="Extended"
                                     ItemContainerStyle="{StaticResource ElementListBoxItemStyle}"
                                     SelectionChanged="OnElementSelectionChanged"/>
                        </DockPanel>
                    </TabItem>
                    <TabItem Header="Structure">
                        <StackPanel Margin="12">
                            <TextBlock Text="Composant Element+" FontWeight="SemiBold"/>
                            <TextBlock Text="Racine du composant" Margin="0,8,0,0"/>
                            <TextBlock Text="{Binding StructureSummary}"
                                       Foreground="{StaticResource MutedBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,12"/>
                            <TextBlock Text="Selection active" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SelectionStateSummary}"
                                       Foreground="{StaticResource MutedBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,4,0,12"/>
                            <UniformGrid Columns="2">
                                <StackPanel Margin="0,0,4,8">
                                    <TextBlock Text="Visibles"/>
                                    <TextBlock Text="{Binding VisibleItemCount}" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Margin="4,0,0,8">
                                    <TextBlock Text="Caches"/>
                                    <TextBlock Text="{Binding HiddenItemCount}" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Margin="0,0,4,8">
                                    <TextBlock Text="Verrouilles"/>
                                    <TextBlock Text="{Binding LockedItemCount}" FontWeight="SemiBold"/>
                                </StackPanel>
                                <StackPanel Margin="4,0,0,8">
                                    <TextBlock Text="Groupes"/>
                                    <TextBlock Text="{Binding GroupCount}" FontWeight="SemiBold"/>
                                </StackPanel>
                            </UniformGrid>
                        </StackPanel>
                    </TabItem>
                    <TabItem Header="Proprietes">
                        <ScrollViewer>
                            <StackPanel Margin="14">
                                <TextBlock Text="Selection" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding SelectionSummary}" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,12"/>

                                <TextBlock Text="Geometrie commune"/>
                                <UniformGrid Columns="2" Margin="0,3,0,8">
                                    <StackPanel Margin="0,0,4,8">
                                        <TextBlock Text="X"/>
                                        <TextBox x:Name="SelectionXTextBox"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,0,8">
                                        <TextBlock Text="Y"/>
                                        <TextBox x:Name="SelectionYTextBox"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,4,8">
                                        <TextBlock Text="Largeur"/>
                                        <TextBox x:Name="SelectionWidthTextBox"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,0,8">
                                        <TextBlock Text="Hauteur"/>
                                        <TextBox x:Name="SelectionHeightTextBox"/>
                                    </StackPanel>
                                </UniformGrid>
                                <Button Content="Appliquer geometrie"
                                        Click="OnApplySelectionGeometryClick"
                                        Margin="0,0,0,12"/>

                                <TextBlock Text="Id source"/>
                                <TextBox Text="{Binding SelectedItem.SourceElementId, Mode=OneWay}" IsReadOnly="True" Margin="0,3,0,8"/>

                                <TextBlock Text="Nom Element+"/>
                                <TextBox Text="{Binding SelectedItem.ElementName, Mode=OneWay}" IsReadOnly="True" Margin="0,3,0,8"/>

                                <TextBlock Text="Nom source"/>
                                <TextBox Text="{Binding SelectedItem.SourceName, Mode=OneWay}" IsReadOnly="True" Margin="0,3,0,8"/>

                                <TextBlock Text="Type legacy"/>
                                <TextBox Text="{Binding SelectedItem.LegacyType, Mode=OneWay}" IsReadOnly="True" Margin="0,3,0,8"/>

                                <UniformGrid Columns="2">
                                    <StackPanel Margin="0,0,4,8">
                                        <TextBlock Text="X"/>
                                        <TextBox Text="{Binding SelectedItem.Bounds.X, Mode=OneWay}" IsReadOnly="True"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,0,8">
                                        <TextBlock Text="Y"/>
                                        <TextBox Text="{Binding SelectedItem.Bounds.Y, Mode=OneWay}" IsReadOnly="True"/>
                                    </StackPanel>
                                    <StackPanel Margin="0,0,4,8">
                                        <TextBlock Text="Largeur"/>
                                        <TextBox Text="{Binding SelectedItem.Bounds.Width, Mode=OneWay}" IsReadOnly="True"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,0,8">
                                        <TextBlock Text="Hauteur"/>
                                        <TextBox Text="{Binding SelectedItem.Bounds.Height, Mode=OneWay}" IsReadOnly="True"/>
                                    </StackPanel>
                                </UniformGrid>

                                <TextBlock Text="Geometrie"/>
                                <TextBox Text="{Binding SelectedItem.GeometrySummary, Mode=OneWay}"
                                         IsReadOnly="True"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="90"
                                         Margin="0,3,0,8"/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="Composant">
                        <StackPanel Margin="14">
                            <TextBlock Text="Definition Element+" FontWeight="SemiBold"/>
                            <TextBlock Text="Nom du composant" Margin="0,10,0,0"/>
                            <TextBox Text="{Binding ComponentName, UpdateSourceTrigger=PropertyChanged}" Margin="0,3,0,8"/>
                            <TextBlock Text="Categorie"/>
                            <TextBox Text="{Binding ComponentCategory, UpdateSourceTrigger=PropertyChanged}" Margin="0,3,0,8"/>
                            <TextBlock Text="Tags"/>
                            <TextBox Text="{Binding ComponentTags, UpdateSourceTrigger=PropertyChanged}" Margin="0,3,0,8"/>
                            <TextBlock Text="Type visuel"/>
                            <TextBox Text="{Binding ComponentVisualKind, Mode=OneWay}" IsReadOnly="True" Margin="0,3,0,8"/>
                            <TextBlock Text="Fichier .sep"/>
                            <TextBox Text="{Binding SavedComponentPath, Mode=OneWay}" IsReadOnly="True" Margin="0,3,0,8"/>
                            <TextBlock Text="{Binding ComponentSummary}" TextWrapping="Wrap" Foreground="{StaticResource MutedBrush}" Margin="0,8,0,0"/>
                        </StackPanel>
                    </TabItem>
                </TabControl>
            </Border>

            <Border Grid.Row="1"
                    Grid.Column="2"
                    Margin="14,0,14,14"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="6">
                <DockPanel Margin="10">
                    <TextBlock DockPanel.Dock="Top"
                               Text="Diagnostics et validation"
                               FontWeight="SemiBold"
                               Margin="0,0,0,6"/>
                    <ListBox ItemsSource="{Binding Diagnostics}" BorderThickness="0"/>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
