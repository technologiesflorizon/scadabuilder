<Window x:Class="ScadaBuilderV2.App.ElementEventDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Evenement Element+"
        Width="620"
        Height="560"
        MinWidth="560"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Window.Resources>
        <SolidColorBrush x:Key="InkBrush" Color="#0F2A30"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#5E7A82"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#F7FBF5"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#DCE8DD"/>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#2090A0"/>
            <Setter Property="BorderBrush" Value="#0F7280"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Margin" Value="0,3,0,10"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Margin" Value="0,3,0,10"/>
        </Style>
    </Window.Resources>

    <Grid Background="#FFFFFF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,0,1"
                Padding="18,16">
            <StackPanel>
                <TextBlock x:Name="ElementTitleText"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource InkBrush}"/>
                <TextBlock Text="Ajouter un comportement runtime a cet Element+. Plusieurs evenements et plusieurs Clic peuvent coexister."
                           Margin="0,5,0,0"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource MutedBrush}"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.05*"/>
                <ColumnDefinition Width="1.35*"/>
            </Grid.ColumnDefinitions>

            <DockPanel Grid.Column="0" Margin="0,0,14,0">
                <TextBlock DockPanel.Dock="Top"
                           Text="Evenements existants"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource InkBrush}"/>
                <TextBlock DockPanel.Dock="Top"
                           x:Name="ExistingEventsSummaryText"
                           Text="Aucun evenement"
                           Margin="0,4,0,8"
                           Foreground="{StaticResource MutedBrush}"
                           TextWrapping="Wrap"/>
                <Button x:Name="DeleteEventButton"
                        DockPanel.Dock="Bottom"
                        Content="Supprimer"
                        Margin="0,8,0,0"
                        IsEnabled="False"
                        Click="OnDeleteClick"/>
                <ListBox x:Name="ExistingEventsListBox"
                         DisplayMemberPath="DisplayName"
                         BorderBrush="{StaticResource BorderBrushSoft}"
                         BorderThickness="1"
                         Background="#FBFDFB"
                         SelectionChanged="OnExistingEventSelectionChanged"/>
            </DockPanel>

            <StackPanel Grid.Column="1">
                <TextBlock Text="Nouveau flow"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource InkBrush}"/>
                <TextBlock Text="Declencheur"
                           Margin="0,12,0,0"/>
                <ComboBox x:Name="TriggerComboBox"
                          DisplayMemberPath="FrenchLabel"/>

                <TextBlock Text="Fonction"/>
                <ComboBox x:Name="ActionComboBox"
                          DisplayMemberPath="FrenchLabel"/>

                <TextBlock Text="Page cible"/>
                <ComboBox x:Name="TargetPageComboBox"
                          DisplayMemberPath="DisplayName"/>

                <TextBlock Text="Condition"/>
                <TextBox Text="Aucune condition"
                         IsReadOnly="True"
                         Foreground="{StaticResource MutedBrush}"/>
                <TextBlock Text="Les conditions sont prevues par le contrat mais restent desactivees pour cette premiere tranche."
                           TextWrapping="Wrap"
                           Foreground="{StaticResource MutedBrush}"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,1,0,0"
                Padding="14"
                Background="#FFFFFF">
            <DockPanel>
                <TextBlock x:Name="ValidationText"
                           VerticalAlignment="Center"
                           Foreground="#A04720"
                           TextWrapping="Wrap"/>
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Fermer"
                            IsCancel="True"/>
                    <Button Content="Ajouter"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="OnAddClick"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
