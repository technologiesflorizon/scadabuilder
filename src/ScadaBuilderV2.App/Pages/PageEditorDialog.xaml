<Window x:Class="ScadaBuilderV2.App.Pages.PageEditorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Page" Width="500" SizeToContent="Height" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Background="#FFF7F9FC">
    <Grid Margin="22">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/><RowDefinition Height="Auto"/><RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="HeadingText" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,18"/>
        <StackPanel Grid.Row="1" Margin="0,0,0,12">
            <TextBlock Text="Code de page" FontWeight="SemiBold"/>
            <TextBox x:Name="PageCodeTextBox" MinHeight="32" Margin="0,5,0,0"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="Titre" FontWeight="SemiBold"/>
            <TextBox x:Name="PageTitleTextBox" MinHeight="32" Margin="0,5,0,0"/>
        </StackPanel>
        <Grid Grid.Row="3" Margin="0,0,0,12">
            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
            <StackPanel Margin="0,0,8,0">
                <TextBlock Text="Type" FontWeight="SemiBold"/>
                <ComboBox x:Name="PageTypeComboBox" SelectedIndex="0" IsEnabled="False" Margin="0,5,0,0"><ComboBoxItem Content="Default"/></ComboBox>
            </StackPanel>
            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                <TextBlock Text="Modèle" FontWeight="SemiBold"/>
                <ComboBox SelectedIndex="0" IsEnabled="False" Margin="0,5,0,0"><ComboBoxItem Content="Blank"/></ComboBox>
            </StackPanel>
        </Grid>
        <CheckBox Grid.Row="4" x:Name="IncludeInBuildCheckBox" Content="Inclure dans le build" IsChecked="False" IsEnabled="False" Margin="0,0,0,14"/>
        <Grid Grid.Row="5">
            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="Auto"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
            <TextBlock x:Name="ValidationText" Foreground="#FFC62828" VerticalAlignment="Center" TextWrapping="Wrap"/>
            <Button Grid.Column="1" Content="Annuler" IsCancel="True" MinWidth="90" Margin="12,0,8,0"/>
            <Button Grid.Column="2" Content="Appliquer" IsDefault="True" MinWidth="96" Click="OnApplyClick"/>
        </Grid>
    </Grid>
</Window>
