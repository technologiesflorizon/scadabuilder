<Window x:Class="ScadaBuilderV2.App.TagSelectionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sélectionner un tag"
        Width="460" Height="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Sélectionnez un tag à insérer dans l’expression :"
                   Margin="0,0,0,10"/>
        <ListBox x:Name="TagListBox"
                 Grid.Row="1"
                 DisplayMemberPath="DisplayLabel"
                 SelectionMode="Single"
                 MouseDoubleClick="OnTagDoubleClick"/>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
            <Button Content="Annuler" IsCancel="True" MinWidth="90" Margin="0,0,8,0"/>
            <Button Content="Sélectionner" IsDefault="True" MinWidth="110" Click="OnSelectClick"/>
        </StackPanel>
    </Grid>
</Window>
