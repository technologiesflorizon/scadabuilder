<Window x:Class="ScadaBuilderV2.App.ColorPickerDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Couleur"
        Width="420"
        Height="610"
        MinWidth="380"
        MinHeight="580"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <Window.Resources>
        <SolidColorBrush x:Key="InkBrush" Color="#0F2A30"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#5E7A82"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#DCE8DD"/>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#2090A0"/>
            <Setter Property="BorderBrush" Value="#0F7280"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
    </Window.Resources>

    <Grid Background="#FFFFFF" Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0">
            <TextBlock Text="CSS fond"
                       FontWeight="SemiBold"/>
            <TextBlock Text="Valeur appliquee apres Enregistrer"
                       Margin="0,2,0,6"
                       Foreground="{StaticResource MutedBrush}"/>
            <Border x:Name="ColorPreview"
                    Height="34"
                    Margin="0,0,0,8"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    Background="#000000"/>
            <Border x:Name="SaturationValuePicker"
                    Height="150"
                    Margin="0,0,0,8"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    MouseDown="OnSaturationValuePickerMouseDown"
                    MouseMove="OnSaturationValuePickerMouseMove"
                    MouseUp="OnSaturationValuePickerMouseUp"
                    SizeChanged="OnSaturationValuePickerSizeChanged">
                <Grid ClipToBounds="True">
                    <Rectangle x:Name="HueColorLayer"/>
                    <Rectangle>
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                <GradientStop Color="#00FFFFFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Rectangle>
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Color="#00000000" Offset="0"/>
                                <GradientStop Color="#FF000000" Offset="1"/>
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                    <Ellipse x:Name="SaturationValueSelector"
                             Width="14"
                             Height="14"
                             Stroke="#FFFFFFFF"
                             StrokeThickness="2"
                             Fill="#33000000"
                             HorizontalAlignment="Left"
                             VerticalAlignment="Top">
                        <Ellipse.RenderTransform>
                            <TranslateTransform x:Name="SaturationValueSelectorTransform"/>
                        </Ellipse.RenderTransform>
                    </Ellipse>
                </Grid>
            </Border>
            <Grid Margin="0,0,0,8">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Border Grid.Row="0"
                        Height="12"
                        Margin="0,0,0,2"
                        CornerRadius="2">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Color="#FFFF0000" Offset="0"/>
                            <GradientStop Color="#FFFFFF00" Offset="0.166"/>
                            <GradientStop Color="#FF00FF00" Offset="0.333"/>
                            <GradientStop Color="#FF00FFFF" Offset="0.5"/>
                            <GradientStop Color="#FF0000FF" Offset="0.666"/>
                            <GradientStop Color="#FFFF00FF" Offset="0.833"/>
                            <GradientStop Color="#FFFF0000" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                </Border>
                <Slider x:Name="HueSlider"
                        Grid.Row="1"
                        Minimum="0"
                        Maximum="360"
                        TickFrequency="1"
                        ValueChanged="OnHueSliderChanged"/>
            </Grid>
            <UniformGrid Columns="6" Margin="0,0,0,8">
                <Button Tag="#000000" Click="OnSwatchClick" ToolTip="Noir" Padding="0">
                    <Border Width="24" Height="20" Background="#000000"/>
                </Button>
                <Button Tag="#ffffff" Click="OnSwatchClick" ToolTip="Blanc" Padding="0">
                    <Border Width="24" Height="20" Background="#ffffff" BorderBrush="#33000000" BorderThickness="1"/>
                </Button>
                <Button Tag="#0f2a30" Click="OnSwatchClick" ToolTip="Florizon fonce" Padding="0">
                    <Border Width="24" Height="20" Background="#0f2a30"/>
                </Button>
                <Button Tag="#f7fbf5" Click="OnSwatchClick" ToolTip="Fond clair" Padding="0">
                    <Border Width="24" Height="20" Background="#f7fbf5" BorderBrush="#33000000" BorderThickness="1"/>
                </Button>
                <Button Tag="#90c030" Click="OnSwatchClick" ToolTip="Vert Florizon" Padding="0">
                    <Border Width="24" Height="20" Background="#90c030"/>
                </Button>
                <Button Tag="#2090a0" Click="OnSwatchClick" ToolTip="Turquoise Florizon" Padding="0">
                    <Border Width="24" Height="20" Background="#2090a0"/>
                </Button>
            </UniformGrid>
            <TextBox x:Name="ColorTextBox"
                     Text="#000000"
                     Margin="0,0,0,6"
                     TextChanged="OnColorTextChanged"/>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="34"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="R" VerticalAlignment="Center"/>
                <Slider x:Name="RedSlider"
                        Grid.Column="1"
                        Minimum="0"
                        Maximum="255"
                        TickFrequency="1"
                        ValueChanged="OnRgbSliderChanged"/>
                <TextBlock x:Name="RedValueText"
                           Grid.Column="2"
                           Text="0"
                           TextAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>
            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="34"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="G" VerticalAlignment="Center"/>
                <Slider x:Name="GreenSlider"
                        Grid.Column="1"
                        Minimum="0"
                        Maximum="255"
                        TickFrequency="1"
                        ValueChanged="OnRgbSliderChanged"/>
                <TextBlock x:Name="GreenValueText"
                           Grid.Column="2"
                           Text="0"
                           TextAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="18"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="34"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="B" VerticalAlignment="Center"/>
                <Slider x:Name="BlueSlider"
                        Grid.Column="1"
                        Minimum="0"
                        Maximum="255"
                        TickFrequency="1"
                        ValueChanged="OnRgbSliderChanged"/>
                <TextBlock x:Name="BlueValueText"
                           Grid.Column="2"
                           Text="0"
                           TextAlignment="Right"
                           VerticalAlignment="Center"/>
            </Grid>
            <TextBlock x:Name="ValidationText"
                       Foreground="#A04720"
                       TextWrapping="Wrap"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Annuler" Click="OnCancelClick"/>
            <Button Content="Enregistrer" Style="{StaticResource PrimaryButtonStyle}" Click="OnSaveClick"/>
        </StackPanel>
    </Grid>
</Window>
