<Window x:Class="ScadaBuilderV2.App.TableEditor.TableNumericInputPropertiesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Input numérique de cellule"
        Width="540" Height="720"
        MinWidth="480" MinHeight="600"
        WindowStartupLocation="CenterOwner">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="Input numérique" FontSize="20" FontWeight="SemiBold"/>
            <TextBlock x:Name="TargetSummaryText" Margin="0,5,0,0" FontWeight="SemiBold" Foreground="#244850" TextWrapping="Wrap"/>
            <TextBlock Text="Configurez le comportement standard et les tags TF100Web de la cellule sélectionnée."
                       Margin="0,4,0,16" Foreground="#5B6870" TextWrapping="Wrap"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <GroupBox Header="Valeur et contraintes" Margin="0,0,0,12">
                    <Grid Margin="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="12"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <StackPanel Grid.Row="0" Grid.Column="0">
                            <TextBlock Text="Valeur initiale"/>
                            <TextBox x:Name="InitialValueTextBox"/>
                        </StackPanel>
                        <StackPanel Grid.Row="0" Grid.Column="2">
                            <TextBlock Text="Placeholder"/>
                            <TextBox x:Name="PlaceholderTextBox"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,10,0,0">
                            <TextBlock Text="Minimum"/>
                            <TextBox x:Name="MinimumTextBox"/>
                        </StackPanel>
                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,10,0,0">
                            <TextBlock Text="Maximum"/>
                            <TextBox x:Name="MaximumTextBox"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,10,0,0">
                            <TextBlock Text="Pas"/>
                            <TextBox x:Name="StepTextBox"/>
                        </StackPanel>
                        <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,10,0,0">
                            <TextBlock Text="Format d'affichage"/>
                            <TextBox x:Name="DisplayFormatTextBox" ToolTip="Exemples : ##.# ou fixed:1"/>
                        </StackPanel>
                        <CheckBox x:Name="ReadOnlyCheckBox" Grid.Row="3" Grid.ColumnSpan="3"
                                  Content="Lecture seule" Margin="0,12,0,0"/>
                    </Grid>
                </GroupBox>

                <GroupBox Header="Bindings TF100Web" Margin="0,0,0,8">
                    <StackPanel Margin="12">
                        <TextBlock Text="Lire valeur" FontWeight="SemiBold"/>
                        <TextBlock x:Name="ReadBindingSummaryText" Foreground="#5B6870" Margin="0,2,0,5"/>
                        <ComboBox x:Name="ReadTagComboBox" DisplayMemberPath="Label" SelectedValuePath="Id"/>
                        <TextBlock x:Name="ReadDefaultNoticeText" Foreground="#376A40" FontSize="11" Margin="0,4,0,0" TextWrapping="Wrap"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,12">
                            <Button Content="Ajouter / Modifier" Click="OnChooseReadBinding" MinWidth="125"/>
                            <Button Content="Supprimer" Click="OnRemoveReadBinding" Margin="8,0,0,0"/>
                        </StackPanel>

                        <TextBlock Text="Écrire valeur" FontWeight="SemiBold"/>
                        <TextBlock x:Name="WriteBindingSummaryText" Foreground="#5B6870" Margin="0,2,0,5"/>
                        <ComboBox x:Name="WriteTagComboBox" DisplayMemberPath="Label" SelectedValuePath="Id" SelectionChanged="OnWriteTagSelectionChanged"/>
                        <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                            <Button Content="Ajouter / Modifier" Click="OnChooseWriteBinding" MinWidth="125"/>
                            <Button Content="Supprimer" Click="OnRemoveWriteBinding" Margin="8,0,0,0"/>
                        </StackPanel>
                    </StackPanel>
                </GroupBox>
            </StackPanel>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,16,0,0">
            <Button Content="Annuler" IsCancel="True" MinWidth="92" Margin="0,0,8,0"/>
            <Button Content="Enregistrer" IsDefault="True" MinWidth="110" Click="OnSaveClick"/>
        </StackPanel>
    </Grid>
</Window>
