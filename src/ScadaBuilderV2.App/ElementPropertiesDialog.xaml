<Window x:Class="ScadaBuilderV2.App.ElementPropertiesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Proprietes Element+"
        Width="620"
        Height="680"
        MinWidth="560"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Window.Resources>
        <SolidColorBrush x:Key="InkBrush" Color="#0F2A30"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#5E7A82"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#F7FBF5"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#DCE8DD"/>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#2090A0"/>
            <Setter Property="BorderBrush" Value="#0F7280"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Margin" Value="0,3,0,10"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Margin" Value="0,3,0,10"/>
        </Style>
    </Window.Resources>

    <Grid Background="#FFFFFF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,0,1"
                Padding="18,16">
            <StackPanel>
                <TextBlock x:Name="ElementTitleText"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource InkBrush}"/>
                <TextBlock Text="Modifier les proprietes de cet Element+."
                           Margin="0,5,0,0"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource MutedBrush}"/>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" Margin="18">
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,8,8,0">
                        <TextBlock Text="Nom"/>
                        <TextBox x:Name="ElementNameTextBox"/>
                        <TextBlock Text="Mode position"/>
                        <ComboBox x:Name="PositionModeComboBox">
                            <ComboBoxItem Content="Absolute"/>
                            <ComboBoxItem Content="Relative"/>
                        </ComboBox>
                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,4,0">
                                <TextBlock Text="X"/>
                                <TextBox x:Name="ElementXTextBox"/>
                            </StackPanel>
                            <StackPanel Margin="4,0,0,0">
                                <TextBlock Text="Y"/>
                                <TextBox x:Name="ElementYTextBox"/>
                            </StackPanel>
                            <StackPanel Margin="0,8,4,0">
                                <TextBlock Text="Largeur"/>
                                <TextBox x:Name="ElementWidthTextBox"/>
                            </StackPanel>
                            <StackPanel Margin="4,8,0,0">
                                <TextBlock Text="Hauteur"/>
                                <TextBox x:Name="ElementHeightTextBox"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Style">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,8,8,0">
                        <TextBlock Text="Police"/>
                        <ComboBox x:Name="FontFamilyComboBox">
                            <ComboBoxItem Content="Segoe UI"/>
                            <ComboBoxItem Content="Arial"/>
                            <ComboBoxItem Content="Calibri"/>
                            <ComboBoxItem Content="Consolas"/>
                        </ComboBox>
                        <TextBlock Text="Taille police"/>
                        <TextBox x:Name="FontSizeTextBox"/>
                        <TextBlock Text="Couleur arriere-plan"/>
                        <ComboBox x:Name="BackgroundComboBox" IsEditable="True">
                            <ComboBoxItem Content="#FFFFFF"/>
                            <ComboBoxItem Content="Transparent"/>
                            <ComboBoxItem Content="#F7FBF5"/>
                            <ComboBoxItem Content="#90C030"/>
                            <ComboBoxItem Content="#2090A0"/>
                        </ComboBox>
                        <TextBlock Text="Bordure"/>
                        <ComboBox x:Name="BorderStyleComboBox">
                            <ComboBoxItem Content="Solid"/>
                            <ComboBoxItem Content="Dashed"/>
                            <ComboBoxItem Content="Dotted"/>
                            <ComboBoxItem Content="None"/>
                        </ComboBox>
                        <TextBlock Text="Largeur bordure (px)"/>
                        <TextBox x:Name="BorderWidthTextBox"/>
                        <TextBlock Text="Shadow"/>
                        <UniformGrid Columns="4" Margin="0,3,0,8">
                            <RadioButton x:Name="ShadowNoneRadio" Content="Aucun" GroupName="ShadowPreset"/>
                            <RadioButton x:Name="ShadowSoftRadio" Content="Soft" GroupName="ShadowPreset"/>
                            <RadioButton x:Name="ShadowRaisedRadio" Content="Lift" GroupName="ShadowPreset"/>
                            <RadioButton x:Name="ShadowInsetRadio" Content="Inset" GroupName="ShadowPreset"/>
                        </UniformGrid>
                        <UniformGrid Columns="2" Margin="0,0,0,8">
                            <StackPanel Margin="0,0,4,0">
                                <TextBlock Text="Opacite (0-1)"/>
                                <TextBox x:Name="OpacityTextBox"/>
                            </StackPanel>
                            <StackPanel Margin="4,0,0,0">
                                <TextBlock Text="Rotation (deg)"/>
                                <TextBox x:Name="RotationTextBox"/>
                            </StackPanel>
                        </UniformGrid>
                        <TextBlock Text="CSS avance"/>
                        <TextBox x:Name="AdvancedCssTextBox"
                                 AcceptsReturn="True"
                                 MinHeight="76"
                                 TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="ButtonTab" Header="Bouton">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,8,8,0">
                        <CheckBox x:Name="ButtonDisabledCheckBox"
                                  Content="Bouton desactive"
                                  Margin="0,0,0,8"/>
                        <CheckBox x:Name="ButtonHoverEnabledCheckBox"
                                  Content="Survol automatique"
                                  Margin="0,0,0,8"/>
                        <TextBlock Text="Fond survol"/>
                        <ComboBox x:Name="ButtonHoverBackgroundComboBox" IsEditable="True">
                            <ComboBoxItem Content="#EAF5F7"/>
                            <ComboBoxItem Content="#F7FBF5"/>
                            <ComboBoxItem Content="#DFF3E7"/>
                            <ComboBoxItem Content="#2090A0"/>
                            <ComboBoxItem Content="#90C030"/>
                        </ComboBox>
                        <TextBlock Text="Texte survol"/>
                        <ComboBox x:Name="ButtonHoverForegroundComboBox" IsEditable="True">
                            <ComboBoxItem Content="#0F2A30"/>
                            <ComboBoxItem Content="#FFFFFF"/>
                            <ComboBoxItem Content="#2090A0"/>
                        </ComboBox>
                        <TextBlock Text="Bordure survol"/>
                        <ComboBox x:Name="ButtonHoverBorderColorComboBox" IsEditable="True">
                            <ComboBoxItem Content="#2090A0"/>
                            <ComboBoxItem Content="#90C030"/>
                            <ComboBoxItem Content="#0F7280"/>
                            <ComboBoxItem Content="#8AA0A6"/>
                        </ComboBox>
                        <CheckBox x:Name="ButtonPressedEnabledCheckBox"
                                  Content="Appui actif automatique"
                                  Margin="0,8,0,8"/>
                        <TextBlock Text="Fond appui"/>
                        <ComboBox x:Name="ButtonPressedBackgroundComboBox" IsEditable="True">
                            <ComboBoxItem Content="#0F7280"/>
                            <ComboBoxItem Content="#2090A0"/>
                            <ComboBoxItem Content="#90C030"/>
                            <ComboBoxItem Content="#C62828"/>
                        </ComboBox>
                        <TextBlock Text="Texte appui"/>
                        <ComboBox x:Name="ButtonPressedForegroundComboBox" IsEditable="True">
                            <ComboBoxItem Content="#FFFFFF"/>
                            <ComboBoxItem Content="#0F2A30"/>
                        </ComboBox>
                        <TextBlock Text="Bordure appui"/>
                        <ComboBox x:Name="ButtonPressedBorderColorComboBox" IsEditable="True">
                            <ComboBoxItem Content="#0F2A30"/>
                            <ComboBoxItem Content="#0F7280"/>
                            <ComboBoxItem Content="#2090A0"/>
                            <ComboBoxItem Content="#C62828"/>
                        </ComboBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Donnees">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,8,8,0">
                        <CheckBox x:Name="ReadOnlyCheckBox"
                                  Content="Lecture seulement"
                                  Margin="0,0,0,8"
                                  Checked="OnReadOnlyChanged"
                                  Unchecked="OnReadOnlyChanged"/>
                        <TextBlock Text="Placeholder"/>
                        <TextBox x:Name="PlaceholderTextBox"/>
                        <TextBlock Text="Valeur par defaut"/>
                        <TextBox x:Name="ValueTextBox"/>
                        <TextBlock Text="Contraintes de saisie" Margin="0,8,0,0"/>
                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,4,0">
                                <TextBlock Text="Min"/>
                                <TextBox x:Name="MinimumTextBox"/>
                            </StackPanel>
                            <StackPanel Margin="4,0,0,0">
                                <TextBlock Text="Max"/>
                                <TextBox x:Name="MaximumTextBox"/>
                            </StackPanel>
                            <StackPanel Margin="0,8,4,0" Visibility="Collapsed">
                                <TextBlock Text="Decimales"/>
                                <TextBox x:Name="DecimalsTextBox"/>
                            </StackPanel>
                            <StackPanel Margin="4,8,0,0" Visibility="Collapsed">
                                <TextBlock Text="Unite"/>
                                <TextBox x:Name="UnitTextBox"/>
                            </StackPanel>
                        </UniformGrid>
                        <TextBlock Text="Format affichage" Margin="0,8,0,0"/>
                        <TextBox x:Name="DisplayFormatTextBox"/>
                        <TextBlock Text="Mapping / Tag" Visibility="Collapsed"/>
                        <TextBox x:Name="TagBindingTextBox" Visibility="Collapsed"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Evenement">
                <StackPanel Margin="0,8,8,0">
                    <TextBlock Text="Evenements runtime"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource InkBrush}"/>
                    <TextBlock x:Name="EventSummaryText"
                               Text="Aucun evenement"
                               Margin="0,4,0,12"
                               TextWrapping="Wrap"
                               Foreground="{StaticResource MutedBrush}"/>
                    <Button x:Name="OpenEventsButton"
                            Content="Evenement"
                            HorizontalAlignment="Left"
                            Click="OnOpenEventsClick"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,1,0,0"
                Padding="14"
                Background="#FFFFFF">
            <DockPanel>
                <TextBlock x:Name="ValidationText"
                           VerticalAlignment="Center"
                           Foreground="#A04720"
                           TextWrapping="Wrap"/>
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Annuler"
                            IsCancel="True"/>
                    <Button Content="Appliquer"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="OnApplyClick"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
