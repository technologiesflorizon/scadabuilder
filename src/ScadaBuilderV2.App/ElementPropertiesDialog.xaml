<Window x:Class="ScadaBuilderV2.App.ElementPropertiesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ScadaBuilderV2.App"
        Title="Proprietes Element+"
        Width="620"
        Height="680"
        MinWidth="560"
        MinHeight="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize">
    <Window.Resources>
        <SolidColorBrush x:Key="InkBrush" Color="#0F2A30"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#5E7A82"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#F7FBF5"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#DCE8DD"/>
        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="34"/>
            <Setter Property="Padding" Value="12,7"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="Background" Value="#FFFFFF"/>
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
        </Style>
        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="#2090A0"/>
            <Setter Property="BorderBrush" Value="#0F7280"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Margin" Value="0,3,0,10"/>
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="Margin" Value="0,3,0,10"/>
        </Style>
    </Window.Resources>

    <Grid Background="#FFFFFF">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,0,1"
                Padding="18,16">
            <StackPanel>
                <TextBlock x:Name="ElementTitleText"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource InkBrush}"/>
                <TextBlock Text="Modifier les proprietes de cet Element+."
                           Margin="0,5,0,0"
                           TextWrapping="Wrap"
                           Foreground="{StaticResource MutedBrush}"/>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" Margin="18">
            <TabItem Header="General">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,8,8,0">
                        <TextBlock Text="Nom"/>
                        <TextBox x:Name="ElementNameTextBox"/>
                        <TextBlock Text="Mode position"/>
                        <ComboBox x:Name="PositionModeComboBox">
                            <ComboBoxItem Content="Absolute"/>
                            <ComboBoxItem Content="Relative"/>
                        </ComboBox>
                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,4,0">
                                <TextBlock Text="X"/>
                                <TextBox x:Name="ElementXTextBox"/>
                            </StackPanel>
                            <StackPanel Margin="4,0,0,0">
                                <TextBlock Text="Y"/>
                                <TextBox x:Name="ElementYTextBox"/>
                            </StackPanel>
                            <StackPanel Margin="0,8,4,0">
                                <TextBlock Text="Largeur"/>
                                <TextBox x:Name="ElementWidthTextBox"/>
                            </StackPanel>
                            <StackPanel Margin="4,8,0,0">
                                <TextBlock Text="Hauteur"/>
                                <TextBox x:Name="ElementHeightTextBox"/>
                            </StackPanel>
                        </UniformGrid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Style">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,8,8,0">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4"><Image Source="{DynamicResource Icon.Property.Typography}" Width="16" Height="16" Margin="0,0,6,0"/><TextBlock Text="Typographie" FontWeight="SemiBold"/></StackPanel>
                        <ComboBox x:Name="FontFamilyComboBox" SelectionChanged="OnStylePreviewChanged">
                            <ComboBoxItem Content="Segoe UI"/>
                            <ComboBoxItem Content="Arial"/>
                            <ComboBoxItem Content="Calibri"/>
                            <ComboBoxItem Content="Consolas"/>
                        </ComboBox>
                        <TextBox x:Name="FontSizeTextBox" TextChanged="OnStylePreviewChanged" ToolTip="Taille de police en pixels"/>
                        <UniformGrid Columns="4" Margin="0,4,0,4">
                            <ToggleButton x:Name="BoldToggle" Content="B" FontWeight="Bold" Checked="OnStylePreviewChanged" Unchecked="OnStylePreviewChanged" ToolTip="Gras"/>
                            <ToggleButton x:Name="ItalicToggle" Content="I" FontStyle="Italic" Checked="OnStylePreviewChanged" Unchecked="OnStylePreviewChanged" ToolTip="Italique"/>
                            <ToggleButton x:Name="UnderlineToggle" Checked="OnStylePreviewChanged" Unchecked="OnStylePreviewChanged" ToolTip="Souligné"><TextBlock Text="U" TextDecorations="Underline"/></ToggleButton>
                            <ToggleButton x:Name="StrikethroughToggle" Checked="OnStylePreviewChanged" Unchecked="OnStylePreviewChanged" ToolTip="Barré"><TextBlock Text="S" TextDecorations="Strikethrough"/></ToggleButton>
                        </UniformGrid>
                        <UniformGrid Columns="4" Margin="0,0,0,4">
                            <RadioButton x:Name="AlignLeftRadio" Content="Gauche" GroupName="TextAlign" Checked="OnStylePreviewChanged"/>
                            <RadioButton x:Name="AlignCenterRadio" Content="Centre" GroupName="TextAlign" Checked="OnStylePreviewChanged"/>
                            <RadioButton x:Name="AlignRightRadio" Content="Droite" GroupName="TextAlign" Checked="OnStylePreviewChanged"/>
                            <RadioButton x:Name="AlignJustifyRadio" Content="Justifié" GroupName="TextAlign" Checked="OnStylePreviewChanged"/>
                        </UniformGrid>
                        <ComboBox x:Name="TextTransformComboBox" SelectionChanged="OnStylePreviewChanged">
                            <ComboBoxItem Content="Aucune" Tag="None"/>
                            <ComboBoxItem Content="Majuscules" Tag="Uppercase"/>
                            <ComboBoxItem Content="Minuscules" Tag="Lowercase"/>
                            <ComboBoxItem Content="Capitaliser" Tag="Capitalize"/>
                        </ComboBox>
                        <UniformGrid Columns="2" Margin="0,4,0,8">
                            <TextBox x:Name="LetterSpacingTextBox" TextChanged="OnStylePreviewChanged" ToolTip="Espacement des lettres (px)"/>
                            <TextBox x:Name="LineHeightTextBox" TextChanged="OnStylePreviewChanged" ToolTip="Interligne (px, 0 = normal)"/>
                        </UniformGrid>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,4"><Image Source="{DynamicResource Icon.Property.Colors}" Width="16" Height="16" Margin="0,0,6,0"/><TextBlock Text="Couleurs" FontWeight="SemiBold"/></StackPanel>
                        <local:ColorPickerField x:Name="ForegroundColorPicker" ColorChanged="OnStylePreviewChanged" ToolTip="Couleur du texte"/>
                        <local:ColorPickerField x:Name="BackgroundColorPicker" ColorChanged="OnStylePreviewChanged" ToolTip="Couleur d'arrière-plan"/>
                        <DockPanel Margin="0,0,0,2">
                            <TextBlock Text="Couleur bordure" VerticalAlignment="Center"/>
                            <CheckBox x:Name="BorderTransparentCheckBox"
                                      Content="Transparent"
                                      DockPanel.Dock="Right"
                                      VerticalAlignment="Center"
                                      Margin="8,0,0,0"
                                      Checked="OnBorderTransparentChanged"
                                      Unchecked="OnBorderTransparentChanged"/>
                        </DockPanel>
                        <local:ColorPickerField x:Name="BorderColorPicker" ColorChanged="OnStylePreviewChanged"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,4"><Image Source="{DynamicResource Icon.Property.Border}" Width="16" Height="16" Margin="0,0,6,0"/><TextBlock Text="Bordure" FontWeight="SemiBold"/></StackPanel>
                        <ComboBox x:Name="BorderStyleComboBox" SelectionChanged="OnStylePreviewChanged">
                            <ComboBoxItem Content="Solid"/>
                            <ComboBoxItem Content="Dashed"/>
                            <ComboBoxItem Content="Dotted"/>
                            <ComboBoxItem Content="Double"/>
                            <ComboBoxItem Content="Groove"/>
                            <ComboBoxItem Content="Ridge"/>
                            <ComboBoxItem Content="Inset"/>
                            <ComboBoxItem Content="Outset"/>
                            <ComboBoxItem Content="None"/>
                        </ComboBox>
                        <TextBox x:Name="BorderWidthTextBox" TextChanged="OnStylePreviewChanged" ToolTip="Largeur de bordure (px)"/>
                        <TextBox x:Name="BorderRadiusTextBox" TextChanged="OnStylePreviewChanged" ToolTip="Rayon uniforme (px)"/>
                        <TextBlock Text="Shadow" FontWeight="SemiBold" Margin="0,4,0,2"/>
                        <UniformGrid Columns="4" Margin="0,3,0,8">
                            <RadioButton x:Name="ShadowNoneRadio" Content="Aucun" GroupName="ShadowPreset"/>
                            <RadioButton x:Name="ShadowSoftRadio" Content="Soft" GroupName="ShadowPreset"/>
                            <RadioButton x:Name="ShadowRaisedRadio" Content="Lift" GroupName="ShadowPreset"/>
                            <RadioButton x:Name="ShadowInsetRadio" Content="Inset" GroupName="ShadowPreset"/>
                        </UniformGrid>
                        <UniformGrid Columns="2" Margin="0,0,0,8">
                            <StackPanel Margin="0,0,4,0">
                                <TextBlock Text="Opacite (0-1)"/>
                                <TextBox x:Name="OpacityTextBox"/>
                            </StackPanel>
                            <StackPanel Margin="4,0,0,0">
                                <TextBlock Text="Rotation (deg)"/>
                                <TextBox x:Name="RotationTextBox"/>
                            </StackPanel>
                        </UniformGrid>
                        <TextBlock Text="Aperçu vivant" FontWeight="SemiBold" Margin="0,8,0,2"/>
                        <Border x:Name="StylePreviewBorder" BorderThickness="1" Padding="8" MinHeight="42">
                            <TextBlock x:Name="StylePreviewText" Text="Aperçu Element+" TextWrapping="Wrap"/>
                        </Border>
                        <TextBlock Text="CSS avancé" FontWeight="SemiBold" Margin="0,8,0,2"/>
                        <TextBox x:Name="AdvancedCssTextBox"
                                 AcceptsReturn="True"
                                 MinHeight="76"
                                 TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem x:Name="ButtonTab" Header="Bouton">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,8,8,0">
                        <CheckBox x:Name="ButtonDisabledCheckBox"
                                  Content="Bouton desactive"
                                  Margin="0,0,0,8"/>
                        <CheckBox x:Name="ButtonHoverEnabledCheckBox"
                                  Content="Survol automatique"
                                  Margin="0,0,0,8"/>
                        <TextBlock Text="Fond survol"/>
                        <local:ColorPickerField x:Name="ButtonHoverBackgroundColorPicker"/>
                        <TextBlock Text="Texte survol"/>
                        <local:ColorPickerField x:Name="ButtonHoverForegroundColorPicker"/>
                        <TextBlock Text="Bordure survol"/>
                        <local:ColorPickerField x:Name="ButtonHoverBorderColorPicker"/>
                        <CheckBox x:Name="ButtonPressedEnabledCheckBox"
                                  Content="Appui actif automatique"
                                  Margin="0,8,0,8"/>
                        <TextBlock Text="Fond appui"/>
                        <local:ColorPickerField x:Name="ButtonPressedBackgroundColorPicker"/>
                        <TextBlock Text="Texte appui"/>
                        <local:ColorPickerField x:Name="ButtonPressedForegroundColorPicker"/>
                        <TextBlock Text="Bordure appui"/>
                        <local:ColorPickerField x:Name="ButtonPressedBorderColorPicker"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Donnees">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="0,8,8,0">
                        <CheckBox x:Name="ReadOnlyCheckBox"
                                  Content="Lecture seulement"
                                  Margin="0,0,0,8"
                                  Checked="OnReadOnlyChanged"
                                  Unchecked="OnReadOnlyChanged"/>
                        <TextBlock Text="Placeholder"/>
                        <TextBox x:Name="PlaceholderTextBox"/>
                        <TextBlock Text="Valeur par defaut"/>
                        <TextBox x:Name="ValueTextBox"/>
                        <TextBlock Text="Contraintes de saisie" Margin="0,8,0,0"/>
                        <UniformGrid Columns="2">
                            <StackPanel Margin="0,0,4,0">
                                <TextBlock Text="Min"/>
                                <TextBox x:Name="MinimumTextBox"/>
                            </StackPanel>
                            <StackPanel Margin="4,0,0,0">
                                <TextBlock Text="Max"/>
                                <TextBox x:Name="MaximumTextBox"/>
                            </StackPanel>
                            <StackPanel Margin="0,8,4,0" Visibility="Collapsed">
                                <TextBlock Text="Decimales"/>
                                <TextBox x:Name="DecimalsTextBox"/>
                            </StackPanel>
                            <StackPanel Margin="4,8,0,0" Visibility="Collapsed">
                                <TextBlock Text="Unite"/>
                                <TextBox x:Name="UnitTextBox"/>
                            </StackPanel>
                        </UniformGrid>
                        <TextBlock Text="Format affichage" Margin="0,8,0,0"/>
                        <TextBox x:Name="DisplayFormatTextBox"/>
                        <TextBlock Text="Mapping / Tag" Visibility="Collapsed"/>
                        <TextBox x:Name="TagBindingTextBox" Visibility="Collapsed"/>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="Etat">
                <StackPanel Margin="0,8,8,0">
                    <TextBlock Text="Evenement d'affichage d'etat"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource InkBrush}"/>
                    <ListBox x:Name="StateRulesListBox" Height="220" SelectionMode="Single" Margin="0,8,0,0"
                             DisplayMemberPath="Name"
                             MouseDoubleClick="OnStateRuleDoubleClick"/>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <Button Content="+ Ajouter" Click="OnAddStateRuleClick" Margin="0,0,6,0"/>
                        <Button Content="Monter" Click="OnMoveStateRuleUpClick" Margin="0,0,6,0"/>
                        <Button Content="Descendre" Click="OnMoveStateRuleDownClick" Margin="0,0,6,0"/>
                        <Button Content="Editer" Click="OnEditStateRuleClick" Margin="0,0,6,0"/>
                        <Button Content="Supprimer" Click="OnDeleteStateRuleClick"/>
                    </StackPanel>

                    <TextBlock Text="Lecture de variable" FontWeight="SemiBold" Foreground="{StaticResource InkBrush}" Margin="0,16,0,0"/>
                    <TextBlock x:Name="ReadVariableSummaryText" Foreground="{StaticResource MutedBrush}" Margin="0,4,0,4" TextWrapping="Wrap"/>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="AddReadVariableButton" Content="+ Lecture de variable..." Click="OnEditReadVariableClick" Margin="0,0,6,0"/>
                        <Button x:Name="EditReadVariableButton" Content="Modifier..." Click="OnEditReadVariableClick" Margin="0,0,6,0"/>
                        <Button x:Name="RemoveReadVariableButton" Content="Supprimer" Click="OnRemoveReadVariableClick"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <TabItem Header="Commande">
                <StackPanel Margin="0,8,8,0">
                    <TextBlock Text="Evenement de commande"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource InkBrush}"/>
                    <ListBox x:Name="CommandsListBox" Height="240" SelectionMode="Single" Margin="0,8,0,8"
                             DisplayMemberPath="Name"
                             MouseDoubleClick="OnCommandDoubleClick"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="+ Ajouter" Click="OnAddCommandClick" Margin="0,0,6,0"/>
                        <Button Content="Editer" Click="OnEditCommandClick" Margin="0,0,6,0"/>
                        <Button Content="Supprimer" Click="OnDeleteCommandClick"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,1,0,0"
                Padding="14"
                Background="#FFFFFF">
            <DockPanel>
                <TextBlock x:Name="ValidationText"
                           VerticalAlignment="Center"
                           Foreground="#A04720"
                           TextWrapping="Wrap"/>
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Annuler"
                            IsCancel="True"/>
                    <Button Content="Appliquer"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="OnApplyClick"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
