                                <Grid Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="18"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="34"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="G" VerticalAlignment="Center"/>
                                    <Slider x:Name="BackgroundGreenSlider"
                                            Grid.Column="1"
                                            Minimum="0"
                                            Maximum="255"
                                            TickFrequency="1"
