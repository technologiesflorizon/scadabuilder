                                                          Checked="OnElementPropertyChanged"
                                                          Unchecked="OnElementPropertyChanged"/>
                                                <TextBlock Text="Fond survol"/>
                                                <ComboBox x:Name="ButtonHoverBackgroundComboBox"
                                                          Margin="0,3,0,8"
                                                          SelectionChanged="OnElementPropertyChanged">
                                                    <ComboBoxItem Content="#EAF5F7"/>
                                                    <ComboBoxItem Content="#F7FBF5"/>
                                                    <ComboBoxItem Content="#DFF3E7"/>
                                                    <ComboBoxItem Content="#2090A0"/>
                                                    <ComboBoxItem Content="#90C030"/>
                                                </ComboBox>
                                                <TextBlock Text="Texte survol"/>
                                                <ComboBox x:Name="ButtonHoverForegroundComboBox"
                                                          Margin="0,3,0,8"
                                                          SelectionChanged="OnElementPropertyChanged">
                                                    <ComboBoxItem Content="#0F2A30"/>
                                                    <ComboBoxItem Content="#FFFFFF"/>
                                                    <ComboBoxItem Content="#2090A0"/>
                                                </ComboBox>
                                                <TextBlock Text="Bordure survol"/>
                                                <ComboBox x:Name="ButtonHoverBorderColorComboBox"
                                                          Margin="0,3,0,8"
                                                          SelectionChanged="OnElementPropertyChanged">
                                                    <ComboBoxItem Content="#2090A0"/>
                                                    <ComboBoxItem Content="#90C030"/>
                                                    <ComboBoxItem Content="#0F7280"/>
                                                    <ComboBoxItem Content="#8AA0A6"/>
                                                </ComboBox>
                                            </StackPanel>
                                        </TabItem>
                                        <TabItem Header="Evenement">
                                            <StackPanel Margin="8">
                                                <TextBlock Text="Evenements runtime"/>
                                                <TextBlock x:Name="ElementEventsSummaryText"
                                                           Text="Aucun evenement"
                                                           Margin="0,3,0,8"
                                                           TextWrapping="Wrap"
                                                           Foreground="{StaticResource MutedBrush}"/>
                                                <Button x:Name="OpenElementEventsButton"
                                                        Content="Evenement"
                                                        HorizontalAlignment="Left"
                                                        Click="OnOpenSelectedElementEventsClick"/>
                                            </StackPanel>
                                        </TabItem>
                                        <TabItem Header="Donnees">
                                            <StackPanel Margin="8">
                                                <TextBlock Text="Placeholder"/>
                                                <TextBox x:Name="ElementPlaceholderTextBox"
                                                         Margin="0,3,0,8"
                                                         TextChanged="OnElementPropertyChanged"/>
                                                <TextBlock Text="Valeur par defaut"/>
                                                <TextBox x:Name="ElementValueTextBox"
                                                         Margin="0,3,0,8"
                                                         TextChanged="OnElementPropertyChanged"/>
                                                <TextBlock Text="Contraintes de saisie" Margin="0,4,0,0"/>
                                                <UniformGrid Columns="2">
                                                    <StackPanel Margin="0,0,4,0">
                                                        <TextBlock Text="Min"/>
                                                        <TextBox x:Name="ElementMinTextBox" TextChanged="OnElementPropertyChanged"/>
                                                    </StackPanel>
                                                    <StackPanel Margin="4,0,0,0">
                                                        <TextBlock Text="Max"/>
                                                        <TextBox x:Name="ElementMaxTextBox" TextChanged="OnElementPropertyChanged"/>
                                                    </StackPanel>
                                                    <StackPanel Margin="0,8,4,0" Visibility="Collapsed">
                                                        <TextBlock Text="Decimales"/>
                                                        <TextBox x:Name="ElementDecimalsTextBox" TextChanged="OnElementPropertyChanged"/>
                                                    </StackPanel>
                                                    <StackPanel Margin="4,8,0,0" Visibility="Collapsed">
                                                        <TextBlock Text="Unite"/>
                                                        <TextBox x:Name="ElementUnitTextBox" TextChanged="OnElementPropertyChanged"/>
                                                    </StackPanel>
                                                </UniformGrid>
                                                <TextBlock Text="Format affichage" Margin="0,8,0,0"/>
                                                <TextBox x:Name="ElementFormatTextBox"
                                                         Margin="0,3,0,8"
                                                         TextChanged="OnElementPropertyChanged"/>
                                                <TextBlock Text="Mapping / Tag" Visibility="Collapsed"/>
                                                <TextBox x:Name="ElementTagBindingTextBox"
                                                         Margin="0,3,0,8"
                                                         Visibility="Collapsed"
                                                         TextChanged="OnElementPropertyChanged"/>
                                            </StackPanel>
                                        </TabItem>
                                    </TabControl>
                                </StackPanel>
                            </ScrollViewer>
                        </TabItem>
                        <TabItem Header="Librairie">
                            <DockPanel Margin="12">
                                <StackPanel DockPanel.Dock="Top">
                                    <TextBlock Text="Element+ disponibles"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}"/>
                                    <TextBlock x:Name="ElementLibraryStatusText"
                                               Text="Librairie non chargee"
                                               Margin="0,4,0,8"
                                               TextWrapping="Wrap"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <Button Content="Rafraichir"
                                            HorizontalAlignment="Left"
                                            Margin="0,0,0,8"
                                            Click="OnRefreshElementLibraryClick"/>
                                </StackPanel>
                                <ListBox x:Name="ElementLibraryListBox"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         PreviewMouseLeftButtonDown="OnElementLibraryPreviewMouseLeftButtonDown"
                                         SelectionChanged="OnElementLibrarySelectionChanged"
                                         PreviewMouseMove="OnElementLibraryPreviewMouseMove"
                                         MouseDoubleClick="OnElementLibraryMouseDoubleClick">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource ElementListBoxItemStyle}">
                                            <Setter Property="Width" Value="92"/>
                                            <Setter Property="Height" Value="112"/>
                                            <Setter Property="Padding" Value="3"/>
                                            <Setter Property="Margin" Value="3"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel ToolTip="{Binding DetailText}">
                                                <Border Height="62"
                                                        CornerRadius="4"
                                                        Background="#F2F8EF"
                                                        BorderBrush="#335E7A82"
                                                        BorderThickness="1"
                                                        Margin="0,0,0,5">
                                                    <Grid>
                                                        <local:HtmlPreviewControl Markup="{Binding PreviewMarkup}"
                                                                                  IsHitTestVisible="False"/>
                                                        <TextBlock Text="{Binding IconText}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   FontWeight="Bold"
                                                                   FontSize="18"
                                                                   Foreground="{StaticResource AccentBlueBrush}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding PreviewMarkup}" Value="{x:Null}">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </Grid>
                                                </Border>
                                                <TextBlock Text="{Binding FileName}"
                                                           FontSize="11"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap"
                                                           MaxHeight="38"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </TabItem>
                    </TabControl>
                </DockPanel>
            </Border>
        </Grid>
    </DockPanel>
</Window>
