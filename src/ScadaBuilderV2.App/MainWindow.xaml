                                        <ComboBox x:Name="BackgroundRepeatComboBox" Margin="0,3,0,8">
                                            <ComboBoxItem Content="no-repeat"/>
                                            <ComboBoxItem Content="repeat"/>
                                            <ComboBoxItem Content="repeat-x"/>
                                            <ComboBoxItem Content="repeat-y"/>
