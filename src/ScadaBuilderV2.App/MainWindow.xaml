                                         BorderThickness="0"
                                         Background="Transparent"
                                         ClipToBounds="True"
                                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                         PreviewMouseLeftButtonDown="OnElementLibraryPreviewMouseLeftButtonDown"
                                         SelectionChanged="OnElementLibrarySelectionChanged"
                                         PreviewMouseMove="OnElementLibraryPreviewMouseMove"
                                         MouseDoubleClick="OnElementLibraryMouseDoubleClick">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel/>
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>
                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource ElementListBoxItemStyle}">
                                            <Setter Property="Width" Value="92"/>
                                            <Setter Property="Height" Value="112"/>
                                            <Setter Property="Padding" Value="3"/>
                                            <Setter Property="Margin" Value="3"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                        </Style>
                                    </ListBox.ItemContainerStyle>
                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel ToolTip="{Binding Item.DetailText}">
                                                <Border Height="62"
                                                        CornerRadius="4"
                                                        Background="#F2F8EF"
                                                        BorderBrush="#335E7A82"
                                                        BorderThickness="1"
                                                        Margin="0,0,0,5"
                                                        ClipToBounds="True">
                                                    <Grid>
                                                        <Image Source="{Binding PreviewImage}"
                                                               Stretch="Uniform"
                                                               IsHitTestVisible="False"/>
                                                        <TextBlock Text="{Binding Item.IconText}"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"
                                                                   FontWeight="Bold"
                                                                   FontSize="18"
                                                                   Foreground="{StaticResource AccentBlueBrush}">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding PreviewImage}" Value="{x:Null}">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                        <Border Background="#CC2F6F4E"
                                                                CornerRadius="3"
                                                                Padding="3,1"
                                                                Margin="2"
                                                                HorizontalAlignment="Right"
                                                                VerticalAlignment="Top"
                                                                ToolTip="{Binding Item.ProvenanceText}">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding Item.Provenance}" Value="AiModernized">
                                                                            <Setter Property="Visibility" Value="Visible"/>
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <TextBlock Text="IA"
                                                                       FontSize="9"
                                                                       FontWeight="Bold"
                                                                       Foreground="White"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>
                                                <TextBlock Text="{Binding Item.FileName}"
                                                           FontSize="11"
                                                           TextAlignment="Center"
                                                           TextWrapping="Wrap"
                                                           MaxHeight="38"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </DockPanel>
                        </avalonDock:LayoutAnchorable>
                    </avalonDock:LayoutAnchorablePane>
                </avalonDock:LayoutPanel>
            </avalonDock:LayoutRoot>
        </avalonDock:DockingManager>
    </DockPanel>
</Window>
