<Window x:Class="ScadaBuilderV2.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:avalonDock="https://github.com/Dirkster99/AvalonDock"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:local="clr-namespace:ScadaBuilderV2.App"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SCADA Builder V2"
        Height="980"
        Width="1520"
        MinHeight="760"
        MinWidth="1180"
        Background="#f7fbf5"
        Loaded="OnLoaded">
    <Window.InputBindings>
        <KeyBinding Key="Z" Modifiers="Control" Command="{x:Static local:MainWindow.UndoSceneCommand}"/>
        <KeyBinding Key="Y" Modifiers="Control" Command="{x:Static local:MainWindow.RedoSceneCommand}"/>
        <KeyBinding Key="Z" Modifiers="Control+Shift" Command="{x:Static local:MainWindow.RedoSceneCommand}"/>
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="{x:Static local:MainWindow.UndoSceneCommand}" Executed="OnUndoCommandExecuted"/>
        <CommandBinding Command="{x:Static local:MainWindow.RedoSceneCommand}" Executed="OnRedoCommandExecuted"/>
    </Window.CommandBindings>
    <Window.Resources>
        <SolidColorBrush x:Key="InkBrush" Color="#0f2a30"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#4e6a71"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#ffffff"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#1A0F2A30"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#90c030"/>
        <SolidColorBrush x:Key="AccentBlueBrush" Color="#2090a0"/>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="Background" Value="#ffffff"/>
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
        </Style>

        <Style x:Key="MenuButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="#ffffff"/>
        </Style>

        <Style x:Key="ActiveMenuButtonStyle" TargetType="Button" BasedOn="{StaticResource MenuButtonStyle}">
            <Setter Property="Background" Value="#DFF3E7"/>
            <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
        </Style>

        <Style x:Key="IconToolButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="72"/>
            <Setter Property="Height" Value="64"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="ToolTipService.ShowOnDisabled" Value="True"/>
        </Style>

        <Style x:Key="RibbonCommandButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="78"/>
            <Setter Property="Height" Value="58"/>
            <Setter Property="Padding" Value="6"/>
            <Setter Property="ToolTipService.ShowOnDisabled" Value="True"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="Background" Value="#DFF3E7"/>
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LargeRibbonCommandButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="44"/>
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="ToolTipService.ShowOnDisabled" Value="True"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsActive}" Value="True">
                    <Setter Property="Background" Value="#DFF3E7"/>
                    <Setter Property="BorderBrush" Value="{StaticResource AccentBlueBrush}"/>
                    <Setter Property="BorderThickness" Value="2"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="RibbonGroupStyle" TargetType="Border">
            <Setter Property="Background" Value="#FAFCF9"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
        </Style>

        <Style x:Key="RibbonGroupHeaderStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}"/>
            <Setter Property="Margin" Value="3,0,0,3"/>
        </Style>

        <Style x:Key="CommandIconStyle" TargetType="Image">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="LargeCommandIconStyle" TargetType="Image">
            <Setter Property="Width" Value="32"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0"/>
        </Style>

        <DataTemplate x:Key="RibbonCommandTemplate">
            <Button Style="{StaticResource RibbonCommandButtonStyle}"
                    ToolTip="{Binding ToolTip}"
                    IsEnabled="{Binding IsEnabled}"
                    Command="{Binding Command}">
                <StackPanel>
                    <Image Style="{StaticResource CommandIconStyle}" Source="{Binding Icon}"/>
                    <TextBlock Text="{Binding Label}" FontSize="12" TextAlignment="Center"/>
                </StackPanel>
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="LargeRibbonCommandTemplate">
            <Button Style="{StaticResource LargeRibbonCommandButtonStyle}"
                    ToolTip="{Binding ToolTip}"
                    IsEnabled="{Binding IsEnabled}"
                    Command="{Binding Command}">
                <StackPanel>
                    <Image Style="{StaticResource LargeCommandIconStyle}" Source="{Binding Icon}"/>
                </StackPanel>
            </Button>
        </DataTemplate>

        <DataTemplate x:Key="RibbonGroupTemplate">
            <Border Style="{StaticResource RibbonGroupStyle}">
                <StackPanel>
                    <TextBlock Style="{StaticResource RibbonGroupHeaderStyle}" Text="{Binding Label}"/>
                    <ItemsControl ItemsSource="{Binding Commands}" ItemTemplate="{StaticResource RibbonCommandTemplate}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Visible"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsShapeGallery}" Value="True">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                    <ItemsControl ItemsSource="{Binding Commands}" ItemTemplate="{StaticResource LargeRibbonCommandTemplate}">
                        <ItemsControl.Style>
                            <Style TargetType="ItemsControl">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsShapeGallery}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ItemsControl.Style>
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="4"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </StackPanel>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="ToolPaletteCommandTemplate">
            <Button Style="{StaticResource IconToolButtonStyle}"
                    ToolTip="{Binding ToolTip}"
                    IsEnabled="{Binding IsEnabled}"
                    Command="{Binding Command}">
                <StackPanel>
                    <Image Style="{StaticResource CommandIconStyle}" Source="{Binding Icon}"/>
                    <TextBlock Text="{Binding Label}" FontSize="11" HorizontalAlignment="Center"/>
                </StackPanel>
            </Button>
        </DataTemplate>

        <Style x:Key="ElementListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#EAF5F7"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#2090A0"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#0F7280"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="Selector.IsSelectionActive" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ItemBorder" Property="Background" Value="#2090A0"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#0F7280"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top"
                Height="196"
                Background="#F2F8EF"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="156"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="14,6,14,0">
                    <TextBlock DockPanel.Dock="Right"
                               Text="SCADA Builder V2"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource InkBrush}"
                               FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal">
                        <Button x:Name="FileMenuButton"
                                Content="Fichier"
                                Style="{StaticResource MenuButtonStyle}"
                                Click="OnMenuButtonClick"
                                Tag="File"/>
                        <Button x:Name="EditMenuButton"
                                Content="Edition"
                                Style="{StaticResource MenuButtonStyle}"
                                Click="OnMenuButtonClick"
                                Tag="Edit"/>
                        <Button x:Name="InsertMenuButton"
                                Content="Inserer"
                                Style="{StaticResource MenuButtonStyle}"
                                Click="OnMenuButtonClick"
                                Tag="Insert"/>
                        <Button x:Name="ScreenMenuButton"
                                Content="Ecran"
                                Style="{StaticResource MenuButtonStyle}"
                                Click="OnMenuButtonClick"
                                Tag="Screen"/>
                        <Button x:Name="SelectionMenuButton"
                                Content="Selection"
                                Style="{StaticResource MenuButtonStyle}"
                                Click="OnMenuButtonClick"
                                Tag="Selection"/>
                        <Button x:Name="ToolsMenuButton"
                                Content="Outils"
                                Style="{StaticResource MenuButtonStyle}"
                                Click="OnMenuButtonClick"
                                Tag="Tools"/>
                        <Menu>
                            <MenuItem Header="Fenetres">
                                <MenuItem Header="Outil" Click="OnShowToolAnchorableClick" />
                                <MenuItem Header="Projet" Click="OnShowProjectAnchorableClick" />
                                <MenuItem Header="Catalogue Tags" Click="OnShowTagCatalogAnchorableClick" />
                                <MenuItem Header="Page" Click="OnShowPageAnchorableClick" />
                                <MenuItem Header="Element" Click="OnShowElementAnchorableClick" />
                                <MenuItem Header="Propriete" Click="OnShowPropertiesAnchorableClick" />
                                <MenuItem Header="Librairie" Click="OnShowLibraryAnchorableClick" />
                                <Separator />
                                <MenuItem Header="Reinitialiser la disposition" Click="OnResetLayoutClick" />
                            </MenuItem>
                        </Menu>
                        <ToggleButton Content="Lock"
                                      Width="52"
                                      Margin="8,0,0,0"
                                      IsChecked="{Binding IsSelectionLocked}" />
                    </StackPanel>
                </DockPanel>

                <Border Grid.Row="1"
                        Margin="14,6,14,8"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <Grid Margin="8">
                        <ScrollViewer x:Name="RibbonCommandSurface"
                                      HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding ActiveRibbonGroups}"
                                          ItemTemplate="{StaticResource RibbonGroupTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom"
                Height="36"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusTextBlock"
                           Grid.Column="0"
                           Text="{Binding StatusText}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{StaticResource MutedBrush}"/>
                <ProgressBar x:Name="Ft100ExportProgressBar"
                             Grid.Column="1"
                             Width="160"
                             Height="6"
                             Margin="12,0,10,0"
                             VerticalAlignment="Center"
                             IsIndeterminate="True"
                             Visibility="Collapsed"/>
                <Button Grid.Column="2"
                        Width="28"
                        Height="26"
                        Padding="0"
                        Content="!"
                        ToolTip="Afficher les diagnostics"
                        Click="OnStatusDiagnosticsClick"/>
            </Grid>
        </Border>

        <avalonDock:DockingManager x:Name="MainDockingManager">
            <avalonDock:LayoutRoot>
                <avalonDock:LayoutPanel Orientation="Horizontal">
                    <avalonDock:LayoutAnchorablePane DockWidth="220">
                        <avalonDock:LayoutAnchorable x:Name="ToolAnchorable" Title="Outil" ContentId="Tool" CanClose="True">
                        <ScrollViewer>
                            <ItemsControl ItemsSource="{Binding ToolPaletteCommands}"
                                          ItemTemplate="{StaticResource ToolPaletteCommandTemplate}"
                                          Margin="10"
                                          VerticalAlignment="Top">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="2"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </ScrollViewer>
                        </avalonDock:LayoutAnchorable>
                        <avalonDock:LayoutAnchorable x:Name="ProjectAnchorable" Title="Projet" ContentId="Project" CanClose="True">
                        <Grid Margin="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0">
                                <TextBlock Text="Source legacy"
                                           FontWeight="Bold"
                                           Foreground="{StaticResource InkBrush}"/>
                                <TextBlock x:Name="ProjectNameText"
                                           Text="(chargement...)"
                                           Margin="0,4,0,12"
                                           Foreground="{StaticResource MutedBrush}"/>
                                <TextBlock Text="Tags SCADA"
                                           FontWeight="SemiBold"/>
                                <TextBlock x:Name="ProjectTagsSummaryText"
                                           Text="Aucun catalogue importe"
                                           Margin="0,4,0,12"
                                           Foreground="{StaticResource MutedBrush}"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="Pages"
                                           FontWeight="SemiBold"/>
                            </StackPanel>
                            <ListBox x:Name="PagesListBox"
                                     Grid.Row="1"
                                     Margin="0,6,0,0"
                                     DisplayMemberPath="Title"
                                     SelectionChanged="OnPageSelectionChanged"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                        </Grid>
                        </avalonDock:LayoutAnchorable>
                        <avalonDock:LayoutAnchorable x:Name="TagCatalogAnchorable" Title="Catalogue Tags" ContentId="TagCatalog" CanClose="True">
                        <DockPanel Margin="12">
                            <Button DockPanel.Dock="Top"
                                    HorizontalAlignment="Left"
                                    Width="34"
                                    MinHeight="32"
                                    Padding="0"
                                    Margin="0,0,0,8"
                                    Content="+"
                                    FontWeight="Bold"
                                    ToolTip="Creer un tag"
                                    Click="OnCreateProjectTagClick"/>
                            <TextBlock DockPanel.Dock="Top"
                                       Text="Creation locale disponible apres import des protocoles projet."
                                       Foreground="{StaticResource MutedBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>
                            <TextBlock x:Name="TagCatalogFilteredSummaryText"
                                       DockPanel.Dock="Top"
                                       Text="Aucun tag affiche"
                                       Foreground="{StaticResource MutedBrush}"
                                       TextWrapping="Wrap"
                                       Margin="0,0,0,8"/>
                            <WrapPanel DockPanel.Dock="Top" Margin="0,0,0,8">
                                <TextBox x:Name="TagCatalogSearchTextBox"
                                         MinHeight="30"
                                         Width="170"
                                         Margin="0,0,8,6"
                                         ToolTip="Recherche tag"
                                         TextChanged="OnTagCatalogFilterChanged"/>
                                <ComboBox x:Name="TagCatalogDeviceFilterComboBox"
                                          MinHeight="30"
                                          Width="135"
                                          Margin="0,0,8,6"
                                          SelectionChanged="OnTagCatalogFilterChanged"/>
                                <ComboBox x:Name="TagCatalogDatatypeFilterComboBox"
                                          MinHeight="30"
                                          Width="115"
                                          Margin="0,0,8,6"
                                          SelectionChanged="OnTagCatalogFilterChanged"/>
                                <ComboBox x:Name="TagCatalogAccessFilterComboBox"
                                          MinHeight="30"
                                          Width="125"
                                          Margin="0,0,8,6"
                                          SelectionChanged="OnTagCatalogFilterChanged"/>
                                <ComboBox x:Name="TagCatalogStateFilterComboBox"
                                          Width="115"
                                          MinHeight="30"
                                          Margin="0,0,0,6"
                                          SelectionChanged="OnTagCatalogFilterChanged"/>
                            </WrapPanel>
                            <DataGrid x:Name="TagCatalogDataGrid"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      HeadersVisibility="Column"
                                      GridLinesVisibility="Horizontal"
                                      BorderBrush="{StaticResource BorderBrushSoft}"
                                      BorderThickness="1">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Nom" Binding="{Binding Name}" Width="1.4*"/>
                                    <DataGridTextColumn Header="Type" Binding="{Binding Datatype}" Width="0.8*"/>
                                    <DataGridTextColumn Header="Appareil" Binding="{Binding Device}" Width="1*"/>
                                    <DataGridTextColumn Header="Adresse" Binding="{Binding Address}" Width="1.2*"/>
                                    <DataGridTextColumn Header="Acces" Binding="{Binding Access}" Width="0.9*"/>
                                    <DataGridTextColumn Header="Etat" Binding="{Binding State}" Width="0.8*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                        </avalonDock:LayoutAnchorable>
                    </avalonDock:LayoutAnchorablePane>

                    <avalonDock:LayoutDocumentPane>
                        <avalonDock:LayoutDocument Title="Canvas" ContentId="Canvas" CanClose="False" CanFloat="False">
                <DockPanel>
                    <TabControl x:Name="SceneTabs"
                                DockPanel.Dock="Top"
                                Height="34"
                                BorderThickness="0"
                                SelectionChanged="OnSceneTabSelectionChanged">
                        <TabControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel MinWidth="92" LastChildFill="True">
                                    <Button DockPanel.Dock="Right"
                                            Width="20"
                                            Height="20"
                                            MinHeight="20"
                                            Padding="0"
                                            Margin="8,0,0,0"
                                            Content="x"
                                            FontWeight="Bold"
                                            ToolTip="Fermer la scene"
                                            Tag="{Binding}"
                                            Click="OnCloseSceneTabClick"/>
                                    <TextBlock Text="{Binding Header}"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"/>
                                </DockPanel>
                            </DataTemplate>
                        </TabControl.ItemTemplate>
                    </TabControl>
                    <Border x:Name="PreviewSurfaceBorder"
                            Background="#ffffff"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            Margin="0">
                        <Grid>
                            <wv2:WebView2 x:Name="PreviewWebView"
                                          Visibility="Collapsed"
                                          AllowDrop="True"
                                          DragOver="OnPreviewWebViewDragOver"
                                          Drop="OnPreviewWebViewDrop"/>
                            <TextBlock x:Name="PreviewPlaceholder"
                                       Text="Workspace / Preview WebView2"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource MutedBrush}"
                                       FontWeight="SemiBold"/>
                        </Grid>
                    </Border>
                </DockPanel>
                        </avalonDock:LayoutDocument>
                    </avalonDock:LayoutDocumentPane>

                    <avalonDock:LayoutAnchorablePane DockWidth="320">
                        <avalonDock:LayoutAnchorable x:Name="PageAnchorable" Title="Page" ContentId="Page" CanClose="True">
                            <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <StackPanel Margin="12">
                                <TextBlock Text="Page active" FontWeight="SemiBold"/>
                                <TextBlock x:Name="ActivePageText" Text="-" Margin="0,4,0,12"/>
                                <TextBlock Text="Source preview" FontWeight="SemiBold"/>
                                <TextBlock x:Name="PreviewSourceText"
                                           Text="-"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource MutedBrush}"/>
                                <Separator Margin="0,12,0,12"/>
                                <TextBlock Text="Proprietes page"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="Nom de l'element"
                                           Margin="0,6,0,0"/>
                                <TextBox x:Name="PageNameTextBox"
                                         Margin="0,3,0,8"
                                         IsReadOnly="True"/>
                                <TextBlock Text="Type"/>
                                <ComboBox x:Name="PageTypeComboBox"
                                          Margin="0,3,0,8"
                                          SelectionChanged="OnPageTypeSelectionChanged">
                                    <ComboBoxItem Content="Defaut"/>
                                    <ComboBoxItem Content="Fragment"/>
                                    <ComboBoxItem Content="Entete"/>
                                    <ComboBoxItem Content="Pied-de-page"/>
                                </ComboBox>
                                <CheckBox x:Name="IncludeInBuildCheckBox"
                                          Content="Compiler cette page"
                                          Margin="0,0,0,6"
                                          Click="OnIncludeInBuildClick"/>
                                <CheckBox x:Name="HomePageCheckBox"
                                          Content="Page d'accueil"
                                          Margin="0,0,0,8"
                                          Click="OnHomePageClick"/>
                                <TextBlock Text="Composition"
                                           FontWeight="SemiBold"
                                           Margin="0,4,0,4"/>
                                <TextBlock Text="Header"/>
                                <ComboBox x:Name="HeaderPageComboBox"
                                          Margin="0,3,0,8"
                                          SelectionChanged="OnPageCompositionSelectionChanged"/>
                                <TextBlock Text="Footer"/>
                                <ComboBox x:Name="FooterPageComboBox"
                                          Margin="0,3,0,8"
                                          SelectionChanged="OnPageCompositionSelectionChanged"/>
                                <TextBlock Text="Dimension"
                                           FontWeight="SemiBold"
                                           Margin="0,4,0,4"/>
                                <UniformGrid Columns="2" Margin="0,0,0,8">
                                    <StackPanel Margin="0,0,4,0">
                                        <TextBlock Text="Largeur"/>
                                        <TextBox x:Name="PageWidthTextBox"
                                                 TextChanged="OnPageDimensionTextChanged"/>
                                    </StackPanel>
                                    <StackPanel Margin="4,0,0,0">
                                        <TextBlock Text="Hauteur"/>
                                        <TextBox x:Name="PageHeightTextBox"
                                                 TextChanged="OnPageDimensionTextChanged"/>
                                    </StackPanel>
                                </UniformGrid>
                                <TextBlock Text="CSS fond"
                                           FontWeight="SemiBold"/>
                                <TextBlock Text="Sauvegarde dans la scene V2"
                                           Margin="0,2,0,6"
                                           Foreground="{StaticResource MutedBrush}"/>
                                <Border x:Name="BackgroundColorPreview"
                                        Height="34"
                                        Margin="0,0,0,8"
                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                        BorderThickness="1"
                                        Background="#000000"/>
                                <Border x:Name="SaturationValuePicker"
                                        Height="150"
                                        Margin="0,0,0,8"
                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                        BorderThickness="1"
                                        MouseDown="OnSaturationValuePickerMouseDown"
                                        MouseMove="OnSaturationValuePickerMouseMove"
                                        MouseUp="OnSaturationValuePickerMouseUp"
                                        SizeChanged="OnSaturationValuePickerSizeChanged">
                                    <Grid ClipToBounds="True">
                                        <Rectangle x:Name="HueColorLayer"/>
                                        <Rectangle>
                                            <Rectangle.Fill>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Color="#FFFFFFFF" Offset="0"/>
                                                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Rectangle.Fill>
                                        </Rectangle>
                                        <Rectangle>
                                            <Rectangle.Fill>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                                    <GradientStop Color="#00000000" Offset="0"/>
                                                    <GradientStop Color="#FF000000" Offset="1"/>
                                                </LinearGradientBrush>
                                            </Rectangle.Fill>
                                        </Rectangle>
                                        <Ellipse x:Name="SaturationValueSelector"
                                                 Width="14"
                                                 Height="14"
                                                 Stroke="#FFFFFFFF"
