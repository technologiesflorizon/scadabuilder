                            </ScrollViewer>
                        </avalonDock:LayoutAnchorable>
                        <avalonDock:LayoutAnchorable x:Name="ElementAnchorable" Title="Element" ContentId="Element" CanClose="True">
                            <DockPanel Margin="12">
                                <StackPanel DockPanel.Dock="Top">
                                    <TextBlock Text="Extraction legacy"
                                               FontWeight="SemiBold"
                                               Foreground="{StaticResource InkBrush}"/>
                                    <TextBlock x:Name="SelectionSummaryText"
                                               Text="Aucun element selectionne"
                                               Margin="0,4,0,8"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <UniformGrid Columns="2" Margin="0,0,0,8">
                                        <Button Content="Masquer"
                                                Click="OnHideSelectedClick"/>
                                        <Button Content="Supprimer"
                                                Click="OnDeleteSelectedLegacyClick"/>
                                        <Button Content="Restaurer"
                                                Click="OnRestoreHiddenClick"/>
                                        <Button Content="Extraire V2"
                                                Click="OnExtractSelectedClick"/>
                                        <Button Content="Conversion Element+"
                                                Click="OnConvertSelectedLegacyTextClick"/>
                                        <Button Content="Effacer sel."
                                                Click="OnClearSelectionClick"/>
                                        <Button Content="Grouper"
                                                Click="OnGroupSelectedClick"/>
                                        <Button Content="Degrouper"
                                                Click="OnUngroupSelectedModernClick"/>
                                    </UniformGrid>
                                    <TextBlock x:Name="ExtractionSummaryText"
                                               Text="0 candidat extrait"
                                               Margin="0,0,0,8"
                                               Foreground="{StaticResource MutedBrush}"/>
                                </StackPanel>
                                <ListBox x:Name="LegacyElementsListBox"
                                         DisplayMemberPath="ListDisplayName"
                                         ItemContainerStyle="{StaticResource ElementListBoxItemStyle}"
                                         SelectionMode="Extended"
                                         SelectionChanged="OnLegacyElementListSelectionChanged"/>
                            </DockPanel>
                        </avalonDock:LayoutAnchorable>
                        <avalonDock:LayoutAnchorable x:Name="PropertiesAnchorable" Title="Propriete" ContentId="Properties" CanClose="True">
                            <ScrollViewer>
                                <StackPanel x:Name="SelectedObjectPropertiesPanel" Margin="12">
                                    <TextBlock Text="Objet selectionne" FontWeight="SemiBold"/>
                                    <TextBlock x:Name="ModernSelectionSummaryText"
                                               Text="Aucun objet V2 selectionne"
                                               Margin="0,4,0,12"
                                               Foreground="{StaticResource MutedBrush}"/>
                                    <Button Content="Supprimer l'objet selectionne"
                                            Margin="0,0,0,10"
                                            Click="OnDeleteSelectedModernElementClick"/>
                                    <Button Content="Degrouper le groupe selectionne"
                                            Margin="0,0,0,10"
                                            Click="OnUngroupSelectedModernClick"/>

                                    <TabControl>
                                        <TabItem Header="General">
                                            <StackPanel Margin="8">
                                                <TextBlock Text="Nom"/>
                                                <TextBox x:Name="ElementNameTextBox"
                                                         Margin="0,3,0,8"
                                                         TextChanged="OnElementPropertyChanged"/>
                                                <CheckBox x:Name="ElementReadOnlyCheckBox"
                                                          Content="Lecture seulement"
                                                          Margin="0,0,0,8"
                                                          Checked="OnElementPropertyChanged"
                                                          Unchecked="OnElementPropertyChanged"/>
                                                <TextBlock Text="Position"/>
                                                <ComboBox x:Name="ElementPositionModeComboBox"
                                                          Margin="0,3,0,8"
                                                          SelectionChanged="OnElementPropertyChanged">
                                                    <ComboBoxItem Content="Absolue"/>
                                                    <ComboBoxItem Content="Relative"/>
                                                </ComboBox>
                                                <UniformGrid Columns="2">
                                                    <StackPanel Margin="0,0,4,0">
                                                        <TextBlock Text="X"/>
                                                        <TextBox x:Name="ElementXTextBox" TextChanged="OnElementPropertyChanged"/>
                                                    </StackPanel>
                                                    <StackPanel Margin="4,0,0,0">
                                                        <TextBlock Text="Y"/>
                                                        <TextBox x:Name="ElementYTextBox" TextChanged="OnElementPropertyChanged"/>
                                                    </StackPanel>
                                                    <StackPanel Margin="0,8,4,0">
                                                        <TextBlock Text="Largeur"/>
                                                        <TextBox x:Name="ElementWidthTextBox" TextChanged="OnElementPropertyChanged"/>
                                                    </StackPanel>
                                                    <StackPanel Margin="4,8,0,0">
                                                        <TextBlock Text="Hauteur"/>
                                                        <TextBox x:Name="ElementHeightTextBox" TextChanged="OnElementPropertyChanged"/>
                                                    </StackPanel>
                                                </UniformGrid>
                                            </StackPanel>
                                        </TabItem>
                                        <TabItem Header="Style">
                                            <StackPanel Margin="8">
                                                <TextBlock Text="Typographie" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                                <TextBlock Text="Famille de police"/>
                                                <ComboBox x:Name="ElementFontFamilyComboBox"
                                                          Margin="0,3,0,8"
                                                          SelectionChanged="OnElementPropertyChanged">
                                                    <ComboBoxItem Content="Segoe UI"/>
                                                    <ComboBoxItem Content="Arial"/>
                                                    <ComboBoxItem Content="Calibri"/>
                                                    <ComboBoxItem Content="Consolas"/>
                                                </ComboBox>
                                                <TextBlock Text="Taille de police (px)"/>
                                                <TextBox x:Name="ElementFontSizeTextBox"
                                                         Margin="0,3,0,8"
                                                         TextChanged="OnElementPropertyChanged"/>
                                                <TextBlock Text="Couleur du texte"/>
                                                <local:ColorPickerField x:Name="ElementForegroundColorPicker"
                                                                        ColorChanged="OnElementPropertyChanged"/>
                                                <TextBlock Text="Formatage" Margin="0,4,0,2"/>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                                    <ToggleButton x:Name="ElementBoldToggle" Content="B" FontWeight="Bold" Width="32" Height="32" Margin="0,0,6,0" Checked="OnElementPropertyChanged" Unchecked="OnElementPropertyChanged"/>
                                                    <ToggleButton x:Name="ElementItalicToggle" Content="I" FontStyle="Italic" Width="32" Height="32" Margin="0,0,6,0" Checked="OnElementPropertyChanged" Unchecked="OnElementPropertyChanged"/>
                                                    <ToggleButton x:Name="ElementUnderlineToggle" Content="U" Width="32" Height="32" Margin="0,0,6,0" Checked="OnElementPropertyChanged" Unchecked="OnElementPropertyChanged"/>
                                                    <ToggleButton x:Name="ElementStrikethroughToggle" Content="S" Width="32" Height="32" Checked="OnElementPropertyChanged" Unchecked="OnElementPropertyChanged"/>
                                                </StackPanel>
                                                <TextBlock Text="Alignement" Margin="0,0,0,2"/>
                                                <UniformGrid Columns="4" Margin="0,0,0,6">
                                                    <RadioButton x:Name="ElementAlignLeftRadio" Content="Gauche" GroupName="ElementTextAlign" Checked="OnElementPropertyChanged"/>
                                                    <RadioButton x:Name="ElementAlignCenterRadio" Content="Centre" GroupName="ElementTextAlign" Checked="OnElementPropertyChanged"/>
                                                    <RadioButton x:Name="ElementAlignRightRadio" Content="Droite" GroupName="ElementTextAlign" Checked="OnElementPropertyChanged"/>
                                                    <RadioButton x:Name="ElementAlignJustifyRadio" Content="Justifié" GroupName="ElementTextAlign" Checked="OnElementPropertyChanged"/>
                                                </UniformGrid>
                                                <TextBlock Text="Transformation du texte" Margin="0,0,0,2"/>
                                                <ComboBox x:Name="ElementTextTransformComboBox" SelectionChanged="OnElementPropertyChanged">
                                                    <ComboBoxItem Content="Aucune" Tag="None"/>
                                                    <ComboBoxItem Content="Majuscules" Tag="Uppercase"/>
                                                    <ComboBoxItem Content="Minuscules" Tag="Lowercase"/>
                                                        <ComboBoxItem Content="Capitaliser" Tag="Capitalize"/>
                                                </ComboBox>
                                                <TextBlock Text="Espacement et interligne" Margin="0,8,0,2"/>
                                                <UniformGrid Columns="2" Margin="0,0,0,2">
                                                    <TextBlock Text="Espacement (px)" Margin="0,0,4,0"/>
                                                    <TextBlock Text="Interligne (px)" Margin="4,0,0,0"/>
                                                </UniformGrid>
                                                <UniformGrid Columns="2" Margin="0,3,0,8">
                                                    <TextBox x:Name="ElementLetterSpacingTextBox" TextChanged="OnElementPropertyChanged" ToolTip="Espacement des lettres (px)"/>
                                                    <TextBox x:Name="ElementLineHeightTextBox" TextChanged="OnElementPropertyChanged" ToolTip="Interligne (px)"/>
                                                </UniformGrid>
                                                <TextBlock Text="Couleurs" FontWeight="SemiBold" Margin="0,0,0,4"/>
                                                <TextBlock Text="Couleur d'arrière-plan"/>
                                                <local:ColorPickerField x:Name="ElementBackgroundColorPicker"
                                                                        ColorChanged="OnElementPropertyChanged"/>
                                                <TextBlock Text="Couleur de bordure"/>
                                                <local:ColorPickerField x:Name="ElementBorderColorPicker"
                                                                        ColorChanged="OnElementPropertyChanged"/>
                                                <TextBlock Text="Bordure" FontWeight="SemiBold" Margin="0,8,0,4"/>
                                                <TextBlock Text="Style de bordure"/>
                                                <ComboBox x:Name="ElementBorderStyleComboBox"
                                                          Margin="0,3,0,8"
                                                          SelectionChanged="OnElementPropertyChanged">
                                                    <ComboBoxItem Content="Solid"/>
                                                    <ComboBoxItem Content="Dashed"/>
                                                    <ComboBoxItem Content="Dotted"/>
                                                    <ComboBoxItem Content="Double"/>
                                                    <ComboBoxItem Content="Groove"/>
                                                    <ComboBoxItem Content="Ridge"/>
                                                    <ComboBoxItem Content="Inset"/>
                                                    <ComboBoxItem Content="Outset"/>
                                                    <ComboBoxItem Content="None"/>
                                                </ComboBox>
                                                <TextBlock Text="Largeur de bordure (px)"/>
                                                        <TextBox x:Name="ElementBorderWidthTextBox"
                                                                 Margin="0,3,0,8"
                                                                 TextChanged="OnElementPropertyChanged"/>
                                                <TextBlock Text="Rayon de bordure uniforme (px)"/>
                                                <TextBox x:Name="ElementBorderRadiusTextBox"
                                                         Margin="0,3,0,8"
                                                         ToolTip="Rayon de bordure uniforme (px)"
                                                         TextChanged="OnElementPropertyChanged"/>
                                                <TextBlock Text="Ombre et effets" FontWeight="SemiBold" Margin="0,0,0,2"/>
                                                <UniformGrid Columns="4" Margin="0,3,0,8">
                                                    <RadioButton x:Name="ShadowNoneRadio" Content="Aucun" GroupName="ShadowPreset" Checked="OnElementPropertyChanged"/>
                                                    <RadioButton x:Name="ShadowSoftRadio" Content="Soft" GroupName="ShadowPreset" Checked="OnElementPropertyChanged"/>
                                                    <RadioButton x:Name="ShadowRaisedRadio" Content="Lift" GroupName="ShadowPreset" Checked="OnElementPropertyChanged"/>
                                                    <RadioButton x:Name="ShadowInsetRadio" Content="Inset" GroupName="ShadowPreset" Checked="OnElementPropertyChanged"/>
                                                </UniformGrid>
                                                <UniformGrid Columns="2" Margin="0,0,0,8">
                                                    <StackPanel Margin="0,0,4,0">
                                                        <TextBlock Text="Opacite (0-1)"/>
                                                        <TextBox x:Name="ElementOpacityTextBox"
                                                                 TextChanged="OnElementPropertyChanged"/>
                                                    </StackPanel>
                                                    <StackPanel Margin="4,0,0,0">
                                                        <TextBlock Text="Rotation (deg)"/>
                                                        <TextBox x:Name="ElementRotationTextBox"
                                                                 TextChanged="OnElementPropertyChanged"/>
                                                    </StackPanel>
                                                </UniformGrid>
                                                <TextBlock Text="Aperçu vivant" FontWeight="SemiBold" Margin="0,4,0,2"/>
                                                <Border x:Name="ElementStylePreviewBorder" BorderThickness="1" Padding="8" MinHeight="36">
                                                    <TextBlock x:Name="ElementStylePreviewText" Text="Aperçu Element+" TextWrapping="Wrap"/>
                                                </Border>
                                                <TextBlock Text="CSS avancé"/>
                                                <TextBox x:Name="ElementAdvancedCssTextBox"
                                                         AcceptsReturn="True"
                                                         MinHeight="76"
                                                         TextWrapping="Wrap"
                                                         TextChanged="OnElementPropertyChanged"/>
                                            </StackPanel>
                                        </TabItem>
                                        <TabItem x:Name="ButtonContextTab" Header="Bouton">
                                            <StackPanel Margin="8">
                                                <TextBlock Text="Comportement bouton"/>
                                                <CheckBox x:Name="ButtonDisabledCheckBox"
                                                          Content="Bouton desactive"
                                                          Margin="0,6,0,8"
                                                          Checked="OnElementPropertyChanged"
                                                          Unchecked="OnElementPropertyChanged"/>
                                                <CheckBox x:Name="ButtonHoverEnabledCheckBox"
                                                          Content="Survol automatique"
                                                          Margin="0,0,0,8"
                                                          Checked="OnElementPropertyChanged"
                                                          Unchecked="OnElementPropertyChanged"/>
                                                <TextBlock Text="Fond survol"/>
                                                <local:ColorPickerField x:Name="ButtonHoverBackgroundColorPicker"
                                                                        ColorChanged="OnElementPropertyChanged"/>
                                                <TextBlock Text="Texte survol"/>
                                                <local:ColorPickerField x:Name="ButtonHoverForegroundColorPicker"
                                                                        ColorChanged="OnElementPropertyChanged"/>
                                                <TextBlock Text="Bordure survol"/>
                                                <local:ColorPickerField x:Name="ButtonHoverBorderColorPicker"
                                                                        ColorChanged="OnElementPropertyChanged"/>
                                                <CheckBox x:Name="ButtonPressedEnabledCheckBox"
                                                          Content="Appui actif automatique"
                                                          Margin="0,6,0,8"
                                                          Checked="OnElementPropertyChanged"
                                                          Unchecked="OnElementPropertyChanged"/>
                                                <TextBlock Text="Fond appui"/>
                                                <local:ColorPickerField x:Name="ButtonPressedBackgroundColorPicker"
                                                                        ColorChanged="OnElementPropertyChanged"/>
                                                <TextBlock Text="Texte appui"/>
                                                <local:ColorPickerField x:Name="ButtonPressedForegroundColorPicker"
                                                                        ColorChanged="OnElementPropertyChanged"/>
                                                <TextBlock Text="Bordure appui"/>
                                                <local:ColorPickerField x:Name="ButtonPressedBorderColorPicker"
                                                                        ColorChanged="OnElementPropertyChanged"/>
                                            </StackPanel>
                                        </TabItem>
                                        <TabItem Header="Etat">
                                            <StackPanel Margin="8">
                                                <TextBlock Text="Evenement d'affichage d'etat"/>
                                                <ListBox x:Name="StateRulesListBox" Height="220" SelectionMode="Single" Margin="0,6,0,0"
                                                         DisplayMemberPath="Name"
                                                         MouseDoubleClick="OnStateRuleDoubleClick"/>
