                                        <TextBlock Text="background-position"/>
                                        <TextBox x:Name="BackgroundPositionTextBox" Margin="0,3,0,8"/>
                                        <TextBlock Text="background-attachment"/>
                                        <ComboBox x:Name="BackgroundAttachmentComboBox" Margin="0,3,0,8">
                                            <ComboBoxItem Content="scroll"/>
                                            <ComboBoxItem Content="fixed"/>
                                            <ComboBoxItem Content="local"/>
                                        </ComboBox>
                                        <TextBlock Text="background-origin"/>
                                        <ComboBox x:Name="BackgroundOriginComboBox" Margin="0,3,0,8">
                                            <ComboBoxItem Content="padding-box"/>
                                            <ComboBoxItem Content="border-box"/>
                                            <ComboBoxItem Content="content-box"/>
                                        </ComboBox>
                                        <TextBlock Text="background-clip"/>
                                        <ComboBox x:Name="BackgroundClipComboBox" Margin="0,3,0,8">
                                            <ComboBoxItem Content="border-box"/>
                                            <ComboBoxItem Content="padding-box"/>
                                            <ComboBoxItem Content="content-box"/>
                                        </ComboBox>
                                        <TextBlock Text="background-blend-mode"/>
                                        <ComboBox x:Name="BackgroundBlendModeComboBox" Margin="0,3,0,8">
                                            <ComboBoxItem Content="normal"/>
                                            <ComboBoxItem Content="multiply"/>
                                            <ComboBoxItem Content="screen"/>
                                            <ComboBoxItem Content="overlay"/>
