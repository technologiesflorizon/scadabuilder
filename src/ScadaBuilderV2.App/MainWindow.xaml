                                                         DisplayMemberPath="Name"
                                                         MouseDoubleClick="OnCommandDoubleClick"/>
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Content="+ Ajouter" Click="OnAddCommandClick" Margin="0,0,6,0"/>
                                                    <Button Content="Editer" Click="OnEditCommandClick" Margin="0,0,6,0"/>
                                                    <Button Content="Supprimer" Click="OnDeleteCommandClick"/>
                                                </StackPanel>
                                            </StackPanel>
                                        </TabItem>
                                        <TabItem Header="Donnees">
                                            <StackPanel Margin="8">
                                                <TextBlock Text="Placeholder"/>
                                                <TextBox x:Name="ElementPlaceholderTextBox"
                                                         Margin="0,3,0,8"
                                                         TextChanged="OnElementPropertyChanged"/>
                                                <TextBlock Text="Valeur par defaut"/>
                                                <TextBox x:Name="ElementValueTextBox"
                                                         Margin="0,3,0,8"
                                                         TextChanged="OnElementPropertyChanged"/>
                                                <TextBlock Text="Contraintes de saisie" Margin="0,4,0,0"/>
                                                <UniformGrid Columns="2">
                                                    <StackPanel Margin="0,0,4,0">
                                                        <TextBlock Text="Min"/>
                                                        <TextBox x:Name="ElementMinTextBox" TextChanged="OnElementPropertyChanged"/>
                                                    </StackPanel>
                                                    <StackPanel Margin="4,0,0,0">
                                                        <TextBlock Text="Max"/>
                                                        <TextBox x:Name="ElementMaxTextBox" TextChanged="OnElementPropertyChanged"/>
                                                    </StackPanel>
                                                    <StackPanel Margin="0,8,4,0" Visibility="Collapsed">
                                                        <TextBlock Text="Decimales"/>
                                                        <TextBox x:Name="ElementDecimalsTextBox" TextChanged="OnElementPropertyChanged"/>
                                                    </StackPanel>
                                                    <StackPanel Margin="4,8,0,0" Visibility="Collapsed">
                                                        <TextBlock Text="Unite"/>
                                                        <TextBox x:Name="ElementUnitTextBox" TextChanged="OnElementPropertyChanged"/>
                                                    </StackPanel>
                                                </UniformGrid>
                                                <TextBlock Text="Format affichage" Margin="0,8,0,0"/>
                                                <TextBox x:Name="ElementFormatTextBox"
                                                         Margin="0,3,0,8"
                                                         TextChanged="OnElementPropertyChanged"/>
                                                <TextBlock Text="Mapping / Tag" Visibility="Collapsed"/>
                                                <TextBox x:Name="ElementTagBindingTextBox"
                                                         Margin="0,3,0,8"
                                                         Visibility="Collapsed"
                                                         TextChanged="OnElementPropertyChanged"/>
                                            </StackPanel>
                                        </TabItem>
                                    </TabControl>
                                </StackPanel>
                            </ScrollViewer>
                        </avalonDock:LayoutAnchorable>
