                            <DockPanel Margin="12">
                                <StackPanel DockPanel.Dock="Top">
                                    <ComboBox x:Name="LibrarySelectorComboBox"
                                              DisplayMemberPath="Name"
                                              Margin="0,0,0,4"
                                              SelectionChanged="OnLibrarySelectorSelectionChanged"/>
                                    <TextBlock x:Name="ElementLibraryStatusText"
