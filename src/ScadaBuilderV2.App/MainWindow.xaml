<Window x:Class="ScadaBuilderV2.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:local="clr-namespace:ScadaBuilderV2.App"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="SCADA Builder V2"
        Height="980"
        Width="1520"
        MinHeight="760"
        MinWidth="1180"
        Background="#f7fbf5"
        Loaded="OnLoaded">
    <Window.InputBindings>
        <KeyBinding Key="Z" Modifiers="Control" Command="{x:Static local:MainWindow.UndoSceneCommand}"/>
        <KeyBinding Key="Y" Modifiers="Control" Command="{x:Static local:MainWindow.RedoSceneCommand}"/>
        <KeyBinding Key="Z" Modifiers="Control+Shift" Command="{x:Static local:MainWindow.RedoSceneCommand}"/>
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="{x:Static local:MainWindow.UndoSceneCommand}" Executed="OnUndoCommandExecuted"/>
        <CommandBinding Command="{x:Static local:MainWindow.RedoSceneCommand}" Executed="OnRedoCommandExecuted"/>
    </Window.CommandBindings>
    <Window.Resources>
        <SolidColorBrush x:Key="InkBrush" Color="#0f2a30"/>
        <SolidColorBrush x:Key="MutedBrush" Color="#4e6a71"/>
        <SolidColorBrush x:Key="PanelBrush" Color="#ffffff"/>
        <SolidColorBrush x:Key="BorderBrushSoft" Color="#1A0F2A30"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#90c030"/>
        <SolidColorBrush x:Key="AccentBlueBrush" Color="#2090a0"/>

        <Style TargetType="Button">
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="3"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
            <Setter Property="Background" Value="#ffffff"/>
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
        </Style>

        <Style x:Key="MenuButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="MinWidth" Value="96"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="IconToolButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="72"/>
            <Setter Property="Height" Value="64"/>
            <Setter Property="Padding" Value="6"/>
        </Style>

        <Style x:Key="RibbonCommandButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Width" Value="84"/>
            <Setter Property="Height" Value="54"/>
            <Setter Property="Padding" Value="6"/>
        </Style>

        <Style x:Key="CommandIconStyle" TargetType="Image">
            <Setter Property="Width" Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,0,4"/>
        </Style>

        <Style x:Key="ElementListBoxItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="6,4"/>
            <Setter Property="Margin" Value="0,1"/>
            <Setter Property="Foreground" Value="{StaticResource InkBrush}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="ItemBorder"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="1"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#EAF5F7"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="ItemBorder" Property="Background" Value="#2090A0"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#0F7280"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected" Value="True"/>
                                    <Condition Property="Selector.IsSelectionActive" Value="False"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="ItemBorder" Property="Background" Value="#2090A0"/>
                                <Setter TargetName="ItemBorder" Property="BorderBrush" Value="#0F7280"/>
                                <Setter Property="Foreground" Value="#FFFFFF"/>
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel LastChildFill="True">
        <Border DockPanel.Dock="Top"
                Height="112"
                Background="#F2F8EF"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="40"/>
                    <RowDefinition Height="72"/>
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="14,6,14,0">
                    <TextBlock DockPanel.Dock="Right"
                               Text="SCADA Builder V2"
                               VerticalAlignment="Center"
                               Foreground="{StaticResource InkBrush}"
                               FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal">
                        <Button Content="Fichier"
                                Style="{StaticResource MenuButtonStyle}"
                                Click="OnMenuButtonClick"
                                Tag="File"/>
                        <Button Content="Edition"
                                Style="{StaticResource MenuButtonStyle}"
                                Click="OnMenuButtonClick"
                                Tag="Edit"/>
                        <Button Content="Inserer"
                                Style="{StaticResource MenuButtonStyle}"
                                Click="OnMenuButtonClick"
                                Tag="Insert"/>
                        <Button Content="Ecran"
                                Style="{StaticResource MenuButtonStyle}"
                                Click="OnMenuButtonClick"
                                Tag="Screen"/>
                        <Button Content="Selection"
                                Style="{StaticResource MenuButtonStyle}"
                                Click="OnMenuButtonClick"
                                Tag="Selection"/>
                        <Button Content="Outils"
                                Style="{StaticResource MenuButtonStyle}"
                                Click="OnMenuButtonClick"
                                Tag="Tools"/>
                    </StackPanel>
                </DockPanel>

                <Border Grid.Row="1"
                        Margin="14,6,14,8"
                        Background="{StaticResource PanelBrush}"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="6">
                    <Grid Margin="8">
                        <StackPanel x:Name="FileRibbon" Orientation="Horizontal">
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" ToolTip="Nouveau projet">
                                <StackPanel>
                                    <Image Style="{StaticResource CommandIconStyle}" Source="{StaticResource Icon.Project.New}"/>
                                    <TextBlock Text="Nouveau" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" ToolTip="Ouvrir un projet">
                                <StackPanel>
                                    <Image Style="{StaticResource CommandIconStyle}" Source="{StaticResource Icon.Project.Open}"/>
                                    <TextBlock Text="Ouvrir" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" ToolTip="Enregistrer" Click="OnSaveSceneClick">
                                <StackPanel>
                                    <Image Style="{StaticResource CommandIconStyle}" Source="{StaticResource Icon.Project.Save}"/>
                                    <TextBlock Text="Save" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" ToolTip="Importer legacy Wonderware/ArchestrA">
                                <StackPanel>
                                    <Image Style="{StaticResource CommandIconStyle}" Source="{StaticResource Icon.Import.Legacy}"/>
                                    <TextBlock Text="Legacy" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" ToolTip="Importer les tags SCADA" Click="OnImportTagsClick">
                                <StackPanel>
                                    <Image Style="{StaticResource CommandIconStyle}" Source="{StaticResource Icon.Import.Legacy}"/>
                                    <TextBlock Text="Tags" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" ToolTip="Exporter dossier FT100" Click="OnExportFt100Click">
                                <StackPanel>
                                    <Image Style="{StaticResource CommandIconStyle}" Source="{StaticResource Icon.Build.FT100}"/>
                                    <TextBlock Text="Build" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" ToolTip="Exporter package FT100 .sb2" Click="OnExportFt100Sb2Click">
                                <StackPanel>
                                    <Image Style="{StaticResource CommandIconStyle}" Source="{StaticResource Icon.Build.FT100}"/>
                                    <TextBlock Text=".sb2" FontSize="12"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <StackPanel x:Name="EditRibbon" Orientation="Horizontal" Visibility="Collapsed">
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" ToolTip="Annuler"
                                    Click="OnUndoClick">
                                <StackPanel>
                                    <Image Style="{StaticResource CommandIconStyle}" Source="{StaticResource Icon.Edit.Undo}"/>
                                    <TextBlock Text="Undo" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" ToolTip="Retablir"
                                    Click="OnRedoClick">
                                <StackPanel>
                                    <Image Style="{StaticResource CommandIconStyle}" Source="{StaticResource Icon.Edit.Redo}"/>
                                    <TextBlock Text="Redo" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Content="Copier"/>
                            <Button Content="Coller"/>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" ToolTip="Afficher les panneaux">
                                <StackPanel>
                                    <Image Style="{StaticResource CommandIconStyle}" Source="{StaticResource Icon.Panel.Restore}"/>
                                    <TextBlock Text="Panneaux" FontSize="12"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <StackPanel x:Name="ScreenRibbon" Orientation="Horizontal" Visibility="Collapsed">
                            <Button Content="Desktop"/>
                            <Button Content="Tablet"/>
                            <Button Content="Mobile"/>
                            <Button Content="Rotate"/>
                            <Button Content="Mesures"/>
                        </StackPanel>

                        <StackPanel x:Name="SelectionRibbon" Orientation="Horizontal" Visibility="Collapsed">
                            <Button Content="Grouper"/>
                            <Button Content="Degrouper"/>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" ToolTip="Verrouiller l'objet">
                                <StackPanel>
                                    <Image Style="{StaticResource CommandIconStyle}" Source="{StaticResource Icon.Object.Lock}"/>
                                    <TextBlock Text="Lock objet" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Content="Z +"/>
                            <Button Content="Z -"/>
                        </StackPanel>

                        <StackPanel x:Name="ToolsRibbon" Orientation="Horizontal" Visibility="Collapsed">
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" ToolTip="Selection">
                                <StackPanel>
                                    <Image Style="{StaticResource CommandIconStyle}" Source="{StaticResource Icon.Tool.Select}"/>
                                    <TextBlock Text="Selection" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" ToolTip="Deplacement">
                                <StackPanel>
                                    <Image Style="{StaticResource CommandIconStyle}" Source="{StaticResource Icon.Tool.Move}"/>
                                    <TextBlock Text="Move" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" ToolTip="Texte">
                                <StackPanel>
                                    <Image Style="{StaticResource CommandIconStyle}" Source="{StaticResource Icon.Tool.Text}"/>
                                    <TextBlock Text="Text" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" ToolTip="Image">
                                <StackPanel>
                                    <Image Style="{StaticResource CommandIconStyle}" Source="{StaticResource Icon.Tool.Image}"/>
                                    <TextBlock Text="Image" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}" ToolTip="Zoom">
                                <StackPanel>
                                    <Image Style="{StaticResource CommandIconStyle}" Source="{StaticResource Icon.Tool.Zoom}"/>
                                    <TextBlock Text="Zoom" FontSize="12"/>
                                </StackPanel>
                            </Button>
                            <Button Content="Configurer"/>
                        </StackPanel>

                        <StackPanel x:Name="InsertRibbon" Orientation="Horizontal" Visibility="Collapsed">
                            <Button Style="{StaticResource RibbonCommandButtonStyle}"
                                    ToolTip="Inserer un champ texte statique"
                                    Click="OnInsertTextClick">
                                <StackPanel>
                                    <Image Style="{StaticResource CommandIconStyle}" Source="{StaticResource Icon.Tool.Text}"/>
                                    <TextBlock Text="Champ texte" FontSize="12" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}"
                                    ToolTip="Inserer un champ d'entree texte"
                                    Click="OnInsertInputTextClick">
                                <StackPanel>
                                    <Image Style="{StaticResource CommandIconStyle}" Source="{StaticResource Icon.Tool.Text}"/>
                                    <TextBlock Text="Entree texte" FontSize="12" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}"
                                    ToolTip="Inserer un champ d'entree numerique"
                                    Click="OnInsertInputNumericClick">
                                <StackPanel>
                                    <TextBlock Text="123" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                    <TextBlock Text="Entree num." FontSize="12" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}"
                                    ToolTip="Inserer un rectangle Element+"
                                    Click="OnInsertRectangleClick">
                                <StackPanel>
                                    <TextBlock Text="[ ]" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                    <TextBlock Text="Rectangle" FontSize="12" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}"
                                    ToolTip="Inserer une ellipse Element+"
                                    Click="OnInsertEllipseClick">
                                <StackPanel>
                                    <TextBlock Text="O" FontWeight="Bold" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                    <TextBlock Text="Ellipse" FontSize="12" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}"
                                    ToolTip="Inserer une ligne Element+"
                                    Click="OnInsertLineClick">
                                <StackPanel>
                                    <TextBlock Text="--" FontWeight="Bold" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                    <TextBlock Text="Ligne" FontSize="12" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}"
                                    ToolTip="Inserer une fleche Element+"
                                    Click="OnInsertArrowClick">
                                <StackPanel>
                                    <TextBlock Text="-&gt;" FontWeight="Bold" FontSize="20" HorizontalAlignment="Center" Margin="0,0,0,2"/>
                                    <TextBlock Text="Fleche" FontSize="12" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}"
                                    ToolTip="Inserer un voyant HMI Element+"
                                    Click="OnInsertIndicatorLampClick">
                                <StackPanel>
                                    <TextBlock Text="LED" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" Margin="0,3,0,5"/>
                                    <TextBlock Text="Voyant" FontSize="12" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}"
                                    ToolTip="Inserer une barre horizontale HMI Element+"
                                    Click="OnInsertHorizontalBarClick">
                                <StackPanel>
                                    <TextBlock Text="[=]" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" Margin="0,2,0,4"/>
                                    <TextBlock Text="Barre H" FontSize="12" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}"
                                    ToolTip="Inserer une barre verticale HMI Element+"
                                    Click="OnInsertVerticalBarClick">
                                <StackPanel>
                                    <TextBlock Text="||" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" Margin="0,2,0,4"/>
                                    <TextBlock Text="Barre V" FontSize="12" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}"
                                    ToolTip="Inserer un reservoir HMI Element+"
                                    Click="OnInsertTankClick">
                                <StackPanel>
                                    <TextBlock Text="TNK" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" Margin="0,3,0,5"/>
                                    <TextBlock Text="Reservoir" FontSize="12" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}"
                                    ToolTip="Inserer un tuyau horizontal HMI Element+"
                                    Click="OnInsertPipeHorizontalClick">
                                <StackPanel>
                                    <TextBlock Text="==" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" Margin="0,2,0,4"/>
                                    <TextBlock Text="Tuyau H" FontSize="12" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}"
                                    ToolTip="Inserer un tuyau vertical HMI Element+"
                                    Click="OnInsertPipeVerticalClick">
                                <StackPanel>
                                    <TextBlock Text="II" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" Margin="0,2,0,4"/>
                                    <TextBlock Text="Tuyau V" FontSize="12" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}"
                                    ToolTip="Inserer une vanne HMI Element+"
                                    Click="OnInsertValveClick">
                                <StackPanel>
                                    <TextBlock Text="VLV" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" Margin="0,3,0,5"/>
                                    <TextBlock Text="Vanne" FontSize="12" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}"
                                    ToolTip="Inserer une pompe HMI Element+"
                                    Click="OnInsertPumpClick">
                                <StackPanel>
                                    <TextBlock Text="PMP" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" Margin="0,3,0,5"/>
                                    <TextBlock Text="Pompe" FontSize="12" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}"
                                    ToolTip="Inserer un moteur HMI Element+"
                                    Click="OnInsertMotorClick">
                                <StackPanel>
                                    <TextBlock Text="MTR" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" Margin="0,3,0,5"/>
                                    <TextBlock Text="Moteur" FontSize="12" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}"
                                    ToolTip="Inserer un ventilateur HMI Element+"
                                    Click="OnInsertFanClick">
                                <StackPanel>
                                    <TextBlock Text="FAN" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" Margin="0,3,0,5"/>
                                    <TextBlock Text="Ventil." FontSize="12" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}"
                                    ToolTip="Inserer un convoyeur HMI Element+"
                                    Click="OnInsertConveyorClick">
                                <StackPanel>
                                    <TextBlock Text="CVY" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" Margin="0,3,0,5"/>
                                    <TextBlock Text="Convoy." FontSize="12" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}"
                                    ToolTip="Inserer une jauge HMI Element+"
                                    Click="OnInsertGaugeClick">
                                <StackPanel>
                                    <TextBlock Text="GAU" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" Margin="0,3,0,5"/>
                                    <TextBlock Text="Jauge" FontSize="12" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}"
                                    ToolTip="Inserer un bouton Element+"
                                    Click="OnInsertButtonClick">
                                <StackPanel>
                                    <TextBlock Text="BTN" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" Margin="0,3,0,5"/>
                                    <TextBlock Text="Bouton" FontSize="12" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}"
                                    ToolTip="Inserer un bouton bascule Element+"
                                    Click="OnInsertToggleButtonClick">
                                <StackPanel>
                                    <TextBlock Text="I/O" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" Margin="0,3,0,5"/>
                                    <TextBlock Text="Toggle" FontSize="12" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}"
                                    ToolTip="Inserer un bouton de navigation Element+"
                                    Click="OnInsertNavigationButtonClick">
                                <StackPanel>
                                    <TextBlock Text="NAV" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" Margin="0,3,0,5"/>
                                    <TextBlock Text="Nav" FontSize="12" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}"
                                    ToolTip="Inserer un bouton acquittement alarme Element+"
                                    Click="OnInsertAlarmAckButtonClick">
                                <StackPanel>
                                    <TextBlock Text="ACK" FontWeight="Bold" FontSize="14" HorizontalAlignment="Center" Margin="0,3,0,5"/>
                                    <TextBlock Text="Ack" FontSize="12" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource RibbonCommandButtonStyle}"
                                    ToolTip="Inserer un bouton arret d'urgence Element+"
                                    Click="OnInsertEmergencyStopButtonClick">
                                <StackPanel>
                                    <TextBlock Text="STOP" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" Margin="0,4,0,6"/>
                                    <TextBlock Text="Arret" FontSize="12" TextAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <Border DockPanel.Dock="Bottom"
                Height="36"
                Background="{StaticResource PanelBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="0,1,0,0">
            <Grid Margin="12,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StatusTextBlock"
                           Grid.Column="0"
                           Text="{Binding StatusText}"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           Foreground="{StaticResource MutedBrush}"/>
                <ProgressBar x:Name="Ft100ExportProgressBar"
                             Grid.Column="1"
                             Width="160"
                             Height="6"
                             Margin="12,0,10,0"
                             VerticalAlignment="Center"
                             IsIndeterminate="True"
                             Visibility="Collapsed"/>
                <Button Grid.Column="2"
                        Width="28"
                        Height="26"
                        Padding="0"
                        Content="!"
                        ToolTip="Afficher les diagnostics"
                        Click="OnStatusDiagnosticsClick"/>
            </Grid>
        </Border>

        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="64"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*" MinWidth="600"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="320" MinWidth="240"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    Background="{StaticResource PanelBrush}"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="0,0,1,0">
                <TabControl TabStripPlacement="Bottom">
                    <TabItem Header="Outil">
                        <ScrollViewer>
                            <UniformGrid Columns="2" Margin="10" VerticalAlignment="Top">
                                <Button Style="{StaticResource IconToolButtonStyle}" ToolTip="Selection">
                                    <StackPanel>
                                        <Image Style="{StaticResource CommandIconStyle}" Source="{StaticResource Icon.Tool.Select}"/>
                                        <TextBlock Text="Select" FontSize="11" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource IconToolButtonStyle}" ToolTip="Deplacement">
                                    <StackPanel>
                                        <Image Style="{StaticResource CommandIconStyle}" Source="{StaticResource Icon.Tool.Move}"/>
                                        <TextBlock Text="Move" FontSize="11" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource IconToolButtonStyle}" ToolTip="Texte">
                                    <StackPanel>
                                        <Image Style="{StaticResource CommandIconStyle}" Source="{StaticResource Icon.Tool.Text}"/>
                                        <TextBlock Text="Texte" FontSize="11" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource IconToolButtonStyle}" ToolTip="Image">
                                    <StackPanel>
                                        <Image Style="{StaticResource CommandIconStyle}" Source="{StaticResource Icon.Tool.Image}"/>
                                        <TextBlock Text="Image" FontSize="11" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource IconToolButtonStyle}" ToolTip="Groupe">
                                    <StackPanel>
                                        <Image Style="{StaticResource CommandIconStyle}" Source="{StaticResource Icon.Tool.Group}"/>
                                        <TextBlock Text="Groupe" FontSize="11" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource IconToolButtonStyle}" ToolTip="Zoom">
                                    <StackPanel>
                                        <Image Style="{StaticResource CommandIconStyle}" Source="{StaticResource Icon.Tool.Zoom}"/>
                                        <TextBlock Text="Zoom" FontSize="11" HorizontalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </UniformGrid>
                        </ScrollViewer>
                    </TabItem>
                    <TabItem Header="Projet">
                        <StackPanel Margin="12">
                            <TextBlock Text="Source legacy"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource InkBrush}"/>
                            <TextBlock x:Name="ProjectNameText"
                                       Text="(chargement...)"
                                       Margin="0,4,0,12"
